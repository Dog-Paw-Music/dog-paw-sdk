def dispatch_target(args: Sequence[str]) -> int:
    """Dispatch the `target` workflow area.

    Purpose:
        Provides the canonical top-level entrypoint for Pi target setup while
        temporarily delegating the real work to the existing bootstrap tool.
    Parameters:
        args: Remaining command-line arguments after `target`.
    Return value:
        Exit code from the delegated bootstrap flow, or `2` for invalid target
        subcommand usage.
    Requirements:
        `BOOTSTRAP_TOOL` must exist and be executable for delegation to succeed.
    Guarantees:
        `target apply ...` maps directly onto the current bootstrap command
        without rewriting the bootstrap-specific options.
    Invariants:
        This dispatcher does not implement bootstrap logic itself.
    """

    if is_help_request(args):
        print_target_help()
        return 0
    if EXPORTED_SDK:
        print(exported_sdk_v1_message("target", args), file=sys.stderr)
        return 2
    if args[0] != "apply":
        print(f"Unsupported target command: {args[0]}", file=sys.stderr)
        print_target_help()
        return 2
    apply_args = rewrite_local_path_option_values(
        args[1:],
        {"--identity-file"},
    )
    return run_external([str(BOOTSTRAP_TOOL), *apply_args])


def dispatch_app_install_headless(args: Sequence[str]) -> int:
    """Dispatch `tools/dogpaw app install headless`.

    Purpose:
        Reuses the existing remote headless-app deployment tool behind the new
        workflow surface instead of reimplementing manifest staging logic.
    Parameters:
        args: Remaining arguments after `app install headless`.
    Return value:
        Exit code from the delegated headless-app deployment tool.
    Requirements:
        `DEPLOY_HEADLESS_APPS_TOOL` must exist and be executable.
    Guarantees:
        Expands transitive `installDependencies` before building and deploying
        headless apps. Flutter install dependencies are installed through the
        existing Flutter install workflow.
    Invariants:
        When no `--manifest` values are present, arguments pass through unchanged.
    """

    delegated_args = rewrite_local_path_option_values(
        args,
        {"--build-dir", "-b", "--manifest"},
    )
    manifest_paths = extract_manifest_option_values(delegated_args)
    if not manifest_paths:
        return run_external([str(DEPLOY_HEADLESS_APPS_TOOL), *delegated_args])

    host_manifest_index = build_host_manifest_index_from_workspace()
    seed_paths = [Path(manifest_path).resolve() for manifest_path in manifest_paths]
    for manifest_path in seed_paths:
        manifest = host_manifest_from_path(manifest_path)
        host_manifest_index.setdefault(manifest.name, manifest)
    seed_manifests = tuple(host_manifest_from_path(manifest_path) for manifest_path in seed_paths)
    try:
        scoped_manifests = expand_manifests_with_install_dependencies(
            seed_manifests,
            host_manifest_index,
        )
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 1

    headless_manifests = tuple(
        manifest for manifest in scoped_manifests if not manifest.is_flutter
    )
    flutter_manifests = tuple(
        manifest for manifest in scoped_manifests if manifest.is_flutter
    )
    build_dir_text = resolve_option_from_args(
        delegated_args,
        {"--build-dir", "-b"},
        str(DEFAULT_CXX_BUILD_DIR),
    )
    build_dir = resolve_local_cli_path(build_dir_text or str(DEFAULT_CXX_BUILD_DIR))
    build_targets = build_targets_for_manifests(scoped_manifests)
    dry_run = "--dry-run" in delegated_args
    keep_cache_on_install = "--keep-cache-on-install" in delegated_args
    if build_targets:
        build_command = ["cmake", "--build", str(build_dir)]
        for target_name in build_targets:
            build_command.extend(["--target", target_name])
        if run_commands([build_command], dry_run) != 0:
            return 1

    if headless_manifests:
        deploy_args = replace_manifest_option_values(
            delegated_args,
            [str(manifest.manifest_path) for manifest in headless_manifests],
        )
        deploy_result = run_external([str(DEPLOY_HEADLESS_APPS_TOOL), *deploy_args])
        if deploy_result != 0:
            return deploy_result

    target = resolve_option_from_args(delegated_args, {"--target", "-t"}, None)
    if target is None:
        target = resolve_target(None)
    for manifest in flutter_manifests:
        flutter_command = [
            str(DOGPAW_TOOL_PATH),
            "app",
            "install",
            "flutter",
            "--target",
            target,
            "--manifest",
            str(manifest.manifest_path),
        ]
        if dry_run:
            flutter_command.append("--dry-run")
        if keep_cache_on_install:
            flutter_command.append("--keep-cache-on-install")
        flutter_result = run_external(flutter_command)
        if flutter_result != 0:
            return flutter_result
    return 0


def dispatch_app_install_flutter(args: Sequence[str]) -> int:
    """Dispatch `tools/dogpaw app install flutter`.

    Purpose:
        Implements a host-side remote Flutter install flow by syncing the
        selected app plus shared Flutter workspace packages/tools to the target
        Pi, then invoking the existing remote build-and-install script there.
    Parameters:
        args: Remaining arguments after `app install flutter`.
    Return value:
