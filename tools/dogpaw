def unimplemented_message(area: str, args: Sequence[str]) -> str:
    """Build an actionable not-yet-implemented workflow message.

    Purpose:
        Keeps later-phase workflow placeholders explicit while pointing users at
        the supported front-door commands that already exist.
    Parameters:
        area: Top-level workflow area that was selected.
        args: Remaining arguments after the area token. The first item, when
            present, is typically the attempted subcommand.
    Return value:
        Human-readable error message for stderr.
    Requirements:
        `area` must be one of the declared workflow areas not currently
        implemented by this dispatcher.
    Guarantees:
        The returned text points users back to the current source-of-truth plan
        and at least one working workflow command.
    Invariants:
        Does not inspect the filesystem or mutate global state.
    """

    attempted = f"{area} {' '.join(args)}".strip()
    return (
        f"'dogpaw {attempted}' is not implemented yet.\n"
        f"Currently supported workflows include:\n"
        f"  dogpaw target apply ...\n"
        f"  dogpaw app install <headless|flutter> ...\n"
        f"  dogpaw debug <cxx|flutter> ...\n"
        f"  dogpaw emulator ...\n"
        f"See the current workflow plan at: {PLAN_PATH.relative_to(WORKSPACE_ROOT)}"
    )


def split_passthrough_args(args: Sequence[str]) -> tuple[list[str], list[str]]:
    """Split dispatcher arguments at the first explicit `--` separator.

    Purpose:
        Keeps wrapper option parsing independent from the remote binary's own
        arguments when subcommands need to forward trailing argv entries.
    Parameters:
        args: Raw argument sequence after a subcommand selector.
    Return value:
        Tuple of `wrapper_args` before `--` and `passthrough_args` after it.
    Requirements:
        None.
    Guarantees:
        The separator itself is omitted from both returned lists.
    Invariants:
        Returned argument order matches the input order.
    """

    if "--" not in args:
        return list(args), []
    separator = list(args).index("--")
    return list(args[:separator]), list(args[separator + 1 :])


def load_manifest_payload(manifest_path: Path) -> dict:
    """Load one Dog Paw manifest from disk.

    Purpose:
        Centralizes manifest parsing for debug and install workflows that need a
        small amount of manifest metadata to compute command arguments.
    Parameters:
        manifest_path: Path to a readable `dogpawapp.json` file.
    Return value:
        Parsed manifest object.
    Requirements:
        `manifest_path` exists and contains valid JSON object text.
    Guarantees:
        Raises `ValueError` if the top-level JSON value is not an object.
    Invariants:
        Reads the manifest without modifying it.
    """

    payload = json.loads(manifest_path.read_text(encoding="utf-8"))
    if not isinstance(payload, dict):
        raise ValueError("Manifest must be a JSON object")
    return payload


def require_manifest_string_field(manifest_path: Path, payload: dict, field_name: str) -> str:
    """Read one required string field from a manifest payload.

    Purpose:
        Keeps manifest validation errors consistent for lightweight dispatcher
        workflows that only need a few manifest fields.
    Parameters:
        manifest_path: Manifest path used only for clear error messages.
        payload: Parsed manifest dictionary.
        field_name: Required top-level field name.
    Return value:
        Non-empty string field value.
    Requirements:
        `payload` came from `load_manifest_payload()`.
    Guarantees:
        Raises `ValueError` with the manifest path when the field is missing or
        not a non-empty string.
    Invariants:
        Does not mutate the payload.
    """

    value = payload.get(field_name)
    if not isinstance(value, str) or value == "":
        raise ValueError(f"Manifest {manifest_path} requires non-empty string field: {field_name}")
    return value


@dataclass(frozen=True)
class FlutterManifestContext:
    """Resolved local and remote metadata for one Flutter app manifest.

    Purpose:
        Centralizes the source-tree facts shared by Flutter install and debug
        workflows so the front door does not duplicate manifest validation and
        relative-path calculations.
    Parameters:
        manifest_path: Absolute local `dogpawapp.json` path.
        manifest_payload: Parsed manifest payload.
        app_name: Manifest `name` field.
        manifest_relative: Manifest path relative to the local Flutter workspace
            root.
        app_dir: Local app directory that contains the manifest.
        app_relative: App directory relative to the local Flutter workspace
            root.
        flutter_project_rel: Manifest `flutterApp` directory name.
        flutter_project_dir: Absolute local Flutter package directory.
    Return value:
        Immutable context bundle for one Flutter app.
    Requirements:
        The manifest must exist under `FLUTTER_WORKSPACE_ROOT` and declare a
        valid `flutterApp` directory.
    Guarantees:
        Construction does not mutate local or remote files.
    Invariants:
        `flutter_project_dir` always lives under `app_dir`.
    """

    manifest_path: Path
    manifest_payload: dict
    app_name: str
    manifest_relative: Path
    app_dir: Path
    app_relative: Path
    flutter_project_rel: str
    flutter_project_dir: Path


def resolve_flutter_manifest_context(manifest_arg: str) -> FlutterManifestContext:
    """Resolve one Flutter manifest into reusable workflow context.

    Purpose:
        Keeps Flutter install/debug behavior aligned by validating manifests in
        one place and deriving the common relative paths used for remote sync.
    Parameters:
        manifest_arg: Local manifest path from CLI input.
    Return value:
        Fully resolved `FlutterManifestContext`.
    Requirements:
        `manifest_arg` names a manifest under `FLUTTER_WORKSPACE_ROOT`.
    Guarantees:
        Raises `ValueError` on invalid paths or missing required fields.
    Invariants:
        Relative paths are always computed against `FLUTTER_WORKSPACE_ROOT`.
    """

    manifest_path = resolve_local_cli_path(manifest_arg)
    if not manifest_path.is_file():
        raise ValueError(f"manifest not found: {manifest_path}")
    try:
        manifest_relative = manifest_path.relative_to(FLUTTER_WORKSPACE_ROOT)
    except ValueError as exc:
        raise ValueError(f"manifest must live under {FLUTTER_WORKSPACE_ROOT}") from exc

    manifest_payload = load_manifest_payload(manifest_path)
    app_name = require_manifest_string_field(manifest_path, manifest_payload, "name")
    flutter_project_rel = require_manifest_string_field(
        manifest_path,
        manifest_payload,
        "flutterApp",
    )
    app_dir = manifest_path.parent
    app_relative = app_dir.relative_to(FLUTTER_WORKSPACE_ROOT)
    flutter_project_dir = (app_dir / flutter_project_rel).resolve()
    if not flutter_project_dir.is_dir():
        raise ValueError(f"Flutter project not found: {flutter_project_dir}")
    return FlutterManifestContext(
        manifest_path=manifest_path,
        manifest_payload=manifest_payload,
        app_name=app_name,
        manifest_relative=manifest_relative,
        app_dir=app_dir,
        app_relative=app_relative,
        flutter_project_rel=flutter_project_rel,
        flutter_project_dir=flutter_project_dir,
    )


def build_flutter_remote_paths(
    context: FlutterManifestContext,
    remote_source_root: PurePosixPath,
) -> dict[str, PurePosixPath]:
    """Build remote source-tree paths for one Flutter app workflow.

    Purpose:
        Ensures install and debug flows agree on where synced packages, tools,
        manifests, and Flutter project files live on the remote Pi.
    Parameters:
        context: Resolved local Flutter manifest metadata.
        remote_source_root: Remote root that should contain the temporary
            Flutter workspace source tree.
    Return value:
        Mapping of named remote paths used by higher-level workflow builders.
    Requirements:
        `remote_source_root` must be an absolute Pi path.
    Guarantees:
        Returns only pure path calculations; no network or filesystem I/O occurs.
    Invariants:
        Returned paths remain under `remote_source_root`.
    """

    remote_ui_root = remote_source_root
    remote_app_dir = remote_ui_root / PurePosixPath(context.app_relative.as_posix())
    return {
        "remote_ui_root": remote_ui_root,
        "remote_ui_tools_dir": remote_ui_root / "tools",
        "remote_packages_dir": remote_ui_root / "packages",
        "remote_app_dir": remote_app_dir,
        "remote_manifest_path": remote_ui_root
        / PurePosixPath(context.manifest_relative.as_posix()),
        "remote_flutter_project_dir": remote_app_dir / context.flutter_project_rel,
    }


def build_flutter_source_sync_commands(
    context: FlutterManifestContext,
    target: str,
    remote_source_root: PurePosixPath,
    remote_app_root: PurePosixPath,
) -> list[list[str]]:
    """Build the common remote source-sync commands for Flutter workflows.

    Purpose:
        Shares the temporary-source sync contract between install and debug so
        both flows stage the same files on the Pi.
    Parameters:
        context: Resolved Flutter manifest context.
        target: Remote SSH target.
        remote_source_root: Remote temporary Flutter workspace source root.
        remote_app_root: Remote installed Dog Paw app root.
    Return value:
        Ordered command list for directory creation and rsync operations.
    Requirements:
        `target` must be a non-empty SSH host string.
    Guarantees:
        Sync set includes shared `packages/`, the selected app tree, and the
        install helper scripts needed by the remote build.
    Invariants:
        The returned list does not depend on current network state.
    """

    remote_paths = build_flutter_remote_paths(context, remote_source_root)
    ssh_transport = shell_join(SSH_BASE_ARGS)
    tools_dir = FLUTTER_WORKSPACE_ROOT / "tools"

    remote_prepare_command = shell_join(
        [
            "mkdir",
            "-p",
            str(remote_paths["remote_ui_tools_dir"]),
            str(remote_paths["remote_packages_dir"]),
            str(remote_paths["remote_app_dir"]),
            str(remote_app_root),
        ]
    )
    return [
        [*SSH_BASE_ARGS, target, remote_prepare_command],
        [
            *RSYNC_BASE_ARGS,
            "-e",
            ssh_transport,
            f"{FLUTTER_WORKSPACE_ROOT / 'packages'}/",
            f"{target}:{remote_paths['remote_packages_dir']}/",
        ],
        [
            *RSYNC_BASE_ARGS,
            "-e",
            ssh_transport,
            f"{context.app_dir}/",
            f"{target}:{remote_paths['remote_app_dir']}/",
        ],
        [
            "rsync",
            "-az",
            "-e",
            ssh_transport,
            str(tools_dir / "build_and_install_flutter_app.sh"),
            str(INSTALL_SUPPORT_TOOLS_ROOT / "install_app.py"),
            str(INSTALL_SUPPORT_TOOLS_ROOT / "install_fingerprint.py"),
            f"{target}:{remote_paths['remote_ui_tools_dir']}/",
        ],
    ]


def build_remote_flutter_install_command(
    context: FlutterManifestContext,
    remote_source_root: PurePosixPath,
    remote_app_root: PurePosixPath,
    remote_flutter_root: PurePosixPath,
    bridge_lib: str,
    build_mode: str,
) -> str:
    """Build the remote build-and-install shell command for one Flutter app.

    Purpose:
        Reuses the existing remote installer so Flutter install and debug flows
        both refresh the installed app root through the same bundle layout.
    Parameters:
        context: Resolved Flutter manifest context.
        remote_source_root: Remote temporary Flutter workspace source root.
        remote_app_root: Remote installed Dog Paw app root.
        remote_flutter_root: Remote Flutter SDK root.
        bridge_lib: Remote bridge library path required by installed Dart apps.
        build_mode: Flutter Linux build mode to pass through.
    Return value:
        Shell command string for one remote `bash -lc` invocation.
    Requirements:
        `build_mode` must be valid for `flutter build linux`.
    Guarantees:
        Returned command adds the remote Flutter SDK to PATH, sets
        `DOGPAW_APP_DIR` for the installer, and fails loudly before the build if
        the required bridge library is missing on the target.
    Invariants:
        The command references only the supplied remote roots.
    """

    remote_paths = build_flutter_remote_paths(context, remote_source_root)
    remote_installer = remote_paths["remote_ui_tools_dir"] / "build_and_install_flutter_app.sh"
    remote_path = f"{remote_flutter_root}/bin:{REMOTE_BASE_PATH}"
    return (
        f"chmod +x {shlex.quote(str(remote_installer))} && "
        f"if [[ ! -f {shlex.quote(bridge_lib)} ]]; then "
        # SDK2 branch note: this bridge ownership is expected to move when sdk2
        # merges, so update this install-time preflight to match the new runtime
        # ownership model instead of preserving the current /home/dppi/libs path.
        # Revisit architecture expectations there too; if sdk2 does not make the
        # source architecture explicit, this install flow must keep guarding
        # against copying a host build onto the Pi by mistake.
        f"echo 'Missing required dogpaw bridge library at {bridge_lib}. "
        f"Installed Dart apps will not start correctly until the bridge is deployed.' >&2; "
        f"exit 1; "
        f"fi && "
        f"env PATH={shlex.quote(remote_path)} "
        f"DOGPAW_APP_DIR={shlex.quote(str(remote_app_root))} "
        f"{shlex.quote(str(remote_installer))} "
        f"--manifest {shlex.quote(str(remote_paths['remote_manifest_path']))} "
        f"--app-root {shlex.quote(str(remote_app_root))} "
        f"--build-mode {shlex.quote(build_mode)}"
    )


