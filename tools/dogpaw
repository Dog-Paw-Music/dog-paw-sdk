        f"'dogpaw {attempted}' is not supported in exported SDK v1.\n"
        "Exported SDK v1 currently supports the emulator-first workflow surface:\n"
        "  dogpaw emulator create ...\n"
        "  dogpaw emulator run ...\n"
        "  dogpaw emulator screen ...\n"
        "  dogpaw emulator install-flutter ...\n"
        "  dogpaw emulator install-headless ...\n"
        "  dogpaw emulator logs ...\n"
        "  dogpaw emulator doctor ..."
    )


def validate_tcp_port_text(port_text: str, option_name: str) -> int:
    """Parse and validate one TCP port option value.

    Purpose:
        Gives remote-debug workflows one shared validation path for user-supplied
        TCP port strings before they are used for local binds, SSH forwards, or
        remote `flutter run` arguments.
    Parameters:
        port_text: Decimal TCP port string from CLI input.
        option_name: Human-readable option name used in validation errors.
    Return value:
        Parsed integer TCP port.
    Requirements:
        `port_text` must be a base-10 integer in the TCP port range.
    Guarantees:
        Raises `ValueError` when the port is invalid.
    Invariants:
        Does not bind, reserve, or mutate any socket state.
    """

    try:
        port = int(port_text)
    except ValueError as exc:
        raise ValueError(f"invalid TCP port for {option_name}: {port_text}") from exc
    if port < 1 or port > 65535:
        raise ValueError(f"invalid TCP port for {option_name}: {port_text}")
    return port


def ensure_local_tcp_port_available(port_text: str) -> None:
    """Fail when the requested localhost TCP port is already occupied.

    Purpose:
        Prevents long remote sync/build work from starting when a static debug
        attach port is already held by another local tunnel or process.
    Parameters:
        port_text: Decimal TCP port string from CLI input.
    Return value:
        None.
    Requirements:
        `port_text` must parse as an integer in the TCP port range.
    Guarantees:
        Raises `ValueError` when the port is invalid or currently unavailable.
    Invariants:
        Leaves the port unbound after a successful check.
    """

    port = validate_tcp_port_text(port_text, "--local-port")
    probe = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        probe.bind(("127.0.0.1", port))
    except OSError as exc:
        raise ValueError(f"local port already in use: {port}") from exc
    finally:
        probe.close()


def choose_available_local_tcp_port() -> str:
    """Allocate one currently free localhost TCP port number.

    Purpose:
        Lets IDE-driven Flutter attach flows avoid brittle fixed local forward
        ports by selecting a fresh ephemeral port for each launch.
    Parameters:
        None.
    Return value:
        Decimal TCP port string that was free at selection time.
    Requirements:
        The local machine must permit binding an ephemeral localhost TCP port.
    Guarantees:
        Returns a syntactically valid TCP port string.
    Invariants:
        The helper releases the probe socket before returning, so the port is
        not reserved after selection.
    """

    probe = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        probe.bind(("127.0.0.1", 0))
        return str(probe.getsockname()[1])
    finally:
        probe.close()


def remove_file_if_exists(path: Path) -> None:
    """Delete one local file when it already exists.

    Purpose:
        Prevents stale Flutter attach metadata files from leaking an old VM
        service URI into a new launch attempt.
    Parameters:
        path: File path to remove if present.
    Return value:
        None.
    Requirements:
        `path` points to the local filesystem.
    Guarantees:
        Missing files are ignored without error.
    Invariants:
        Parent directories are not removed.
    """

    try:
        path.unlink()
    except FileNotFoundError:
        return


def write_flutter_service_info_file(path: Path, uri: str) -> None:
    """Write Dart/Flutter attach metadata for file-driven IDE attach.

    Purpose:
        Bridges custom `tools/dogpaw debug flutter` launches to the Dart debug
        adapter by materializing the selected forwarded localhost VM service URI
        in the JSON shape currently used by this workflow.
    Parameters:
        path: Local file path the IDE will poll.
        uri: Local VM service websocket URI exposed through the SSH tunnel.
    Return value:
        None.
    Requirements:
        `uri` must be a valid websocket URI reachable from the local machine.
    Guarantees:
        Parent directories are created and the file is replaced for the current
        launch attempt.
    Invariants:
        The JSON payload always contains exactly one top-level `uri` field.
    """

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps({"uri": uri}), encoding="utf-8")


def stream_flutter_debug_launch(
    launch_command: Sequence[str],
    local_port: str,
    service_info_file: Path | None,
) -> int:
    """Run the long-lived Flutter SSH tunnel and stream its output.

    Purpose:
        Keeps the remote `flutter run` session alive for IDE attach while
        translating the remote ready signal into a local `vmServiceInfoFile`
        update once the forwarded tunnel is actually the intended attach target.
    Parameters:
        launch_command: SSH command that owns both the port forward and the
            remote Flutter process lifecycle.
        local_port: Selected localhost port exposed to the IDE.
        service_info_file: Optional local metadata file to write when the VM
            service becomes attach-ready.
    Return value:
        Child process exit code.
    Requirements:
        `launch_command` must be executable and produce readiness output on
        stdout or stderr.
    Guarantees:
        Child output is relayed to stdout, stale service-info files are cleared
        before launch, and termination signals are forwarded to the SSH process
        group.
    Invariants:
        The helper never writes service-info metadata before the remote launch
        reports `Flutter VM service ready: ...`.
    """

    if service_info_file is not None:
        remove_file_if_exists(service_info_file)
    process = subprocess.Popen(
        list(launch_command),
        cwd=INVOCATION_CWD,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
        start_new_session=True,
    )
    original_handlers: dict[int, object] = {}

    def forward_signal_to_child(signum: int, _frame: object) -> None:
        if process.poll() is None:
            try:
                os.killpg(process.pid, signum)
            except ProcessLookupError:
                pass

    for signal_name in ("SIGINT", "SIGTERM", "SIGHUP"):
        if hasattr(signal, signal_name):
            signum = getattr(signal, signal_name)
            original_handlers[signum] = signal.getsignal(signum)
            signal.signal(signum, forward_signal_to_child)

    wrote_service_info = False
    local_vmservice_uri = f"ws://127.0.0.1:{local_port}/ws"
    try:
        if process.stdout is not None:
            for raw_line in process.stdout:
                print(raw_line, end="", flush=True)
                if (
                    service_info_file is not None
                    and not wrote_service_info
                    and raw_line.startswith("Flutter VM service ready: ")
                ):
                    write_flutter_service_info_file(
                        service_info_file,
                        local_vmservice_uri,
                    )
                    print(
                        f"Flutter attach metadata ready: {local_vmservice_uri}",
                        flush=True,
                    )
                    wrote_service_info = True
        return int(process.wait())
    finally:
        for signum, handler in original_handlers.items():
            signal.signal(signum, handler)
        if service_info_file is not None and not wrote_service_info:
            remove_file_if_exists(service_info_file)
        if process.poll() is None:
            try:
                os.killpg(process.pid, signal.SIGTERM)
            except ProcessLookupError:
                pass
            try:
                process.wait(timeout=5)
            except subprocess.TimeoutExpired:
                try:
                    os.killpg(process.pid, signal.SIGKILL)
                except ProcessLookupError:
                    pass
                process.wait(timeout=5)


def run_commands(commands: Sequence[Sequence[str]], dry_run: bool) -> int:
    """Run a sequence of external commands or print them for dry-run mode.

    Purpose:
        Keeps multi-step workflow implementations consistent across dry-run and
        real execution modes.
    Parameters:
        commands: Ordered command vectors to print or execute.
        dry_run: When true, print the commands instead of executing them.
    Return value:
        `0` when all commands succeed or when dry-run printing completes;
        otherwise the first failing command's exit code.
    Requirements:
        Each command vector must contain at least one token.
    Guarantees:
        Commands run in order from the user's invocation directory. Dry-run mode
        emits one shell-safe line per command.
    Invariants:
        This helper does not mutate command contents between print and execute
        paths.
    """

    for command in commands:
        if dry_run:
            print(shell_join(command))
            continue
        exit_code = run_external(command)
        if exit_code != 0:
            return exit_code
    return 0


def resolve_local_cli_path(path_text: str) -> Path:
    """Resolve one local CLI path argument from the invocation directory.
    
    Purpose:
        Keeps local file and directory arguments consistent whether `dogpaw` is
        launched as `./tools/dogpaw` from the repo root or via a PATH entry from
        some other directory.
    Parameters:
        path_text: User-provided local path argument. May be absolute, relative,
            or start with `~`.
    Return value:
        Absolute normalized local filesystem path.
    Requirements:
        `path_text` names a local path, not a remote target path on the Pi.
    Guarantees:
        Relative paths are anchored at the user's original invocation directory,
        not at the repository root or any delegated tool directory.
    Invariants:
        Path resolution is pure; it does not create files or directories.
    """

    local_path = Path(path_text).expanduser()
    if not local_path.is_absolute():
        local_path = INVOCATION_CWD / local_path
    return local_path.resolve()


def rewrite_local_path_option_values(
    args: Sequence[str],
    local_path_options: set[str],
) -> list[str]:
    """Rewrite selected option values to absolute local paths.

    Purpose:
        Normalizes delegated-tool arguments whose values refer to local files or
        directories so the effective path semantics stay tied to the user's
        invocation directory and dry-run output matches real execution.
    Parameters:
        args: Raw option sequence to rewrite.
        local_path_options: Option names whose next token, or `--opt=value`
            payload, should be treated as a local path.
    Return value:
        New argument list with matching local path option values rewritten to
        absolute paths.
    Requirements:
        `local_path_options` must contain only options whose values are local
        filesystem paths. Remote Pi paths must not be included.
    Guarantees:
        Argument order is preserved. Tokens after a literal `--` separator are
        left untouched.
    Invariants:
        Does not inspect or mutate tokens for options outside
        `local_path_options`.
    """

    rewritten_args: list[str] = []
    index = 0
    while index < len(args):
        token = args[index]
        if token == "--":
            rewritten_args.extend(args[index:])
            break

        matched_inline_option = False
        for option_name in local_path_options:
            inline_prefix = f"{option_name}="
            if token.startswith(inline_prefix):
                resolved_value = resolve_local_cli_path(token[len(inline_prefix) :])
                rewritten_args.append(f"{option_name}={resolved_value}")
                matched_inline_option = True
                break
        if matched_inline_option:
            index += 1
            continue

        rewritten_args.append(token)
        if token in local_path_options and index + 1 < len(args):
            rewritten_args.append(str(resolve_local_cli_path(args[index + 1])))
            index += 2
            continue
        index += 1

    return rewritten_args


def resolve_target(explicit_target: str | None) -> str:
    """Resolve the SSH target for remote workflows.

    Purpose:
        Keeps target lookup consistent across remote install and setup commands
        by honoring an explicit flag first, then the existing local config
        helper, then a final repository default.
    Parameters:
        explicit_target: User-supplied SSH target, or `None`.
    Return value:
        SSH target string in `user@host` form.
    Requirements:
        None.
    Guarantees:
        Returns a non-empty target string when local config lookup succeeds or
        when the built-in fallback is used.
    Invariants:
        Does not persist configuration changes.
    """

    if explicit_target is not None and explicit_target != "":
        return explicit_target
    if LOCAL_CONFIG_TOOL.is_file() and LOCAL_CONFIG_TOOL.stat().st_mode & 0o111:
        completed = subprocess.run(
            [str(LOCAL_CONFIG_TOOL), "--target"],
            cwd=WORKSPACE_ROOT,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )
        if completed.returncode == 0:
            resolved = completed.stdout.strip()
            if resolved != "":
                return resolved
    return "dppi@dogpaw"


