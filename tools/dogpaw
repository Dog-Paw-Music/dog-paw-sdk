        command.
    Requirements:
        Manifest path must exist and live under `FLUTTER_WORKSPACE_ROOT`.
    Guarantees:
        The sync set includes only shared `packages/`, the specific app tree,
        and the install scripts needed for the remote build.
    Invariants:
        Dry-run mode does not create, modify, or delete local or remote files.
    """

    parser = build_flutter_install_parser()
    parsed = parser.parse_args(list(args))
    try:
        context = resolve_flutter_manifest_context(parsed.manifest)
    except ValueError as exc:
        parser.error(str(exc))
        raise AssertionError("unreachable") from exc

    target = resolve_target(parsed.target)
    remote_source_root = PurePosixPath(parsed.remote_source_root)
    remote_app_root = PurePosixPath(parsed.remote_app_root)
    remote_flutter_root = PurePosixPath(parsed.remote_flutter_root)
    host_source_fingerprint = compute_flutter_host_source_fingerprint(
        context,
