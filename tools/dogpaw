def resolve_uninstall_app_name(app_name: str | None, manifest_arg: str | None) -> str:
    """Resolve the app name for uninstall from CLI identity inputs.

    Purpose:
        Lets uninstall accept either an explicit installed app name or a source
        manifest path while keeping one clear app-identity string for remote
        inventory lookup and deletion.
    Parameters:
        app_name: Explicit app name from `--appName`, or `None`.
        manifest_arg: Local manifest path from `--manifest`, or `None`.
    Return value:
        Non-empty Dog Paw app name string.
    Requirements:
        Exactly one of `app_name` or `manifest_arg` should be provided by the
        parser.
    Guarantees:
        Manifest mode validates that the source manifest contains a non-empty
        `name` field.
    Invariants:
        Resolves local manifest identity only; does not inspect remote state.
    """

    if app_name is not None and app_name != "":
        return app_name
    if manifest_arg is None:
        raise ValueError("Either --appName or --manifest is required")
    manifest_path = resolve_local_cli_path(manifest_arg)
    payload = load_manifest_payload(manifest_path)
    return require_manifest_string_field(manifest_path, payload, "name")


def resolve_hardware_profile(explicit_profile: str | None) -> str:
    """Resolve the Dog Paw hardware profile for remote deploy globals.

    Purpose:
        Keeps hardware-profile lookup aligned with the existing local config
        helper so install-updated follows the same target-profile defaults as the
        other Pi workflows.
    Parameters:
        explicit_profile: User-supplied hardware profile string, or `None`.
    Return value:
        Non-empty hardware profile name.
    Requirements:
        None.
    Guarantees:
        Honors an explicit profile first, then `local_config.sh`, then the
        repository default `p8_2`.
    Invariants:
        Does not persist configuration changes.
    """

    if explicit_profile is not None and explicit_profile != "":
        return explicit_profile
    if LOCAL_CONFIG_TOOL.is_file() and LOCAL_CONFIG_TOOL.stat().st_mode & 0o111:
        completed = subprocess.run(
            [str(LOCAL_CONFIG_TOOL), "--hardware-profile"],
            cwd=WORKSPACE_ROOT,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )
        if completed.returncode == 0:
            resolved = completed.stdout.strip()
            if resolved != "":
                return resolved
    return "p8_2"


def build_remote_write_json_command(path: PurePosixPath, payload: dict[str, object]) -> str:
    """Build one remote command that writes a JSON object to a file.

    Purpose:
        Lets install-updated update remote metadata such as the globals
        fingerprint file without requiring a separate helper script on the target.
    Parameters:
        path: Remote file path that should receive the JSON payload.
        payload: JSON-serializable object to write.
    Return value:
        Shell command string suitable for one SSH invocation.
    Requirements:
        `payload` must be serializable by `json.dumps()`.
    Guarantees:
        Creates parent directories when needed and writes a trailing newline.
    Invariants:
        Does not inspect current remote file contents.
    """

    rendered_payload = json.dumps(payload, indent=2, sort_keys=True)
    return (
        "python3 -c "
        + shlex.quote(
            "from pathlib import Path\n"
            f"path = Path({str(path)!r})\n"
            "path.parent.mkdir(parents=True, exist_ok=True)\n"
            f"path.write_text({(rendered_payload + chr(10))!r}, encoding='utf-8')\n"
        )
    )


def dispatch_app_install_updated(args: Sequence[str]) -> int:
    """Dispatch `tools/dogpaw app install-updated`.

    Purpose:
        Implements the host-driven stale-app update workflow for Pi targets using
        the existing headless deploy, Flutter install, and deploy-and-run helper
        paths.
    Parameters:
        args: Remaining arguments after `app install-updated`.
    Return value:
        Exit code from the planning or execution path.
    Requirements:
        The caller runs from a workspace with valid Dog Paw manifests and has SSH
        access to the selected target.
    Guarantees:
        Dry-run mode prints the planned commands. Real execution runs the build,
        prune, deploy, and metadata-update steps in order.
    Invariants:
        Unknown installed apps warn and skip; they are never pruned silently.
    """

    parser = build_app_install_updated_parser()
    parsed = parser.parse_args(
        rewrite_local_path_option_values(args, {"--build-dir", "--startup-plan"})
    )
    target = resolve_target(parsed.target)
    build_dir = resolve_local_cli_path(parsed.build_dir)
    startup_plan = resolve_local_cli_path(parsed.startup_plan)
    hardware_profile = resolve_hardware_profile(parsed.hardware_profile)
    remote_app_root = PurePosixPath(parsed.remote_app_root)
    remote_script_dir = PurePosixPath(parsed.remote_script_dir)
    remote_flutter_root = PurePosixPath(parsed.remote_flutter_root)

    remote_state = load_install_updated_remote_state(
        target=target,
        remote_app_root=remote_app_root,
        remote_script_dir=remote_script_dir,
        remote_flutter_root=remote_flutter_root,
    )
    if remote_state.target_hardware_profile != hardware_profile:
        parser.error(
            "target hardware profile mismatch: "
            f"workspace={hardware_profile}, target={remote_state.target_hardware_profile or '<missing>'}"
        )
        raise AssertionError("unreachable")

    host_manifest_index = build_host_manifest_index_from_workspace()
    startup_names: tuple[str, ...] = ()
    if parsed.include_startup_plan:
        startup_names = startup_plan_app_names(startup_plan)
    try:
        seed_manifests = collect_install_updated_seed_manifests(
            host_manifest_index=host_manifest_index,
            remote_apps=remote_state.remote_apps,
            include_startup_plan=parsed.include_startup_plan,
            startup_plan_app_names=startup_names,
        )
        scoped_manifests = expand_manifests_with_install_dependencies(
            seed_manifests,
            host_manifest_index,
        )
    except ValueError as exc:
        parser.error(str(exc))
        raise AssertionError("unreachable") from exc
    build_targets = build_targets_for_manifests(scoped_manifests)
    build_commands: list[list[str]] = []
    if build_targets:
        build_command = ["cmake", "--build", str(build_dir)]
        for target_name in build_targets:
            build_command.extend(["--target", target_name])
        build_commands.append(build_command)
    if run_commands(build_commands, parsed.dry_run) != 0:
        return 1

    globals_fingerprint = compute_deploy_globals_fingerprint(hardware_profile)
    globals_metadata = remote_state.globals_metadata or {}
    globals_stale = globals_metadata.get("fingerprint") != globals_fingerprint

    needs_flutter_sdk = any(manifest.is_flutter for manifest in scoped_manifests)
    current_flutter_sdk_version = remote_state.flutter_sdk_version
    if needs_flutter_sdk:
        current_flutter_sdk_version = read_remote_flutter_sdk_version(target, remote_flutter_root)

    plan = plan_install_updated(
        host_manifest_index=host_manifest_index,
        remote_apps=remote_state.remote_apps,
        include_startup_plan=parsed.include_startup_plan,
        startup_plan_app_names=startup_names,
        current_pi_flutter_sdk_version=current_flutter_sdk_version,
        build_mode=parsed.build_mode,
        build_dir=build_dir,
        globals_stale=globals_stale,
    )
    for warning in plan.warnings:
        print(warning, file=sys.stderr)

    commands: list[list[str]] = []
    for orphan_dir in plan.orphaned_app_dirs:
        commands.append([*SSH_BASE_ARGS, target, f"rm -rf {shlex.quote(str(orphan_dir))}"])

    if plan.globals_stale:
        commands.append(
            [
                str(DEPLOY_HEADLESS_APPS_TOOL),
                "--target",
                target,
                "--hardware-profile",
                hardware_profile,
                "--globals-only",
                *([] if not parsed.dry_run else ["--dry-run"]),
            ]
        )
        globals_payload = {
            "schemaVersion": 1,
            "fingerprint": globals_fingerprint,
            "hardwareProfile": hardware_profile,
            "installedAt": datetime.now(timezone.utc).isoformat(),
        }
        commands.append(
            [
                *SSH_BASE_ARGS,
                target,
                build_remote_write_json_command(
                    globals_metadata_remote_path(remote_script_dir),
                    globals_payload,
                ),
            ]
        )

    if plan.stale_headless_manifests:
        headless_command = [
            str(DEPLOY_HEADLESS_APPS_TOOL),
            "--target",
            target,
            "--hardware-profile",
            hardware_profile,
            "--build-dir",
            str(build_dir),
        ]
        if parsed.dry_run:
            headless_command.append("--dry-run")
        if parsed.keep_cache_on_install:
            headless_command.append("--keep-cache-on-install")
        for manifest_path in plan.stale_headless_manifests:
            headless_command.extend(["--manifest", str(manifest_path)])
        commands.append(headless_command)

    for manifest_path in plan.stale_flutter_manifests:
        flutter_command = [
            str(DOGPAW_TOOL_PATH),
            "app",
            "install",
            "flutter",
            "--target",
            target,
            "--manifest",
            str(manifest_path),
            "--build-mode",
            parsed.build_mode,
        ]
        if parsed.dry_run:
            flutter_command.append("--dry-run")
        if parsed.keep_cache_on_install:
            flutter_command.append("--keep-cache-on-install")
        commands.append(flutter_command)

    epiphany_path = build_dir / "bin" / "Epiphany"
    epiphany_command = [
        str(DEPLOY_AND_RUN_TOOL),
        "--target",
        target,
        "--sync-only",
        "-s",
        str(epiphany_path),
    ]
    if parsed.dry_run:
        epiphany_command.append("--skip-missing")
    commands.append(epiphany_command)

    return run_commands(commands, parsed.dry_run)


def dispatch_app_uninstall(args: Sequence[str]) -> int:
    """Dispatch `tools/dogpaw app uninstall`.

    Purpose:
        Removes one installed app directory from the target Dog Paw app registry
        after confirming that the app currently exists on the selected target.
    Parameters:
        args: Remaining arguments after `app uninstall`.
    Return value:
        Exit code from the dry-run or remote remove command.
    Requirements:
        The caller provides exactly one app identity source via `--appName` or
        `--manifest`, and SSH access to the target works.
    Guarantees:
        Only the installed app directory under the configured remote app root is
        removed. Infrastructure binaries and unrelated runtime files are left
        untouched.
    Invariants:
        Does not silently prune apps that are not currently installed.
    """

    parser = build_app_uninstall_parser()
    parsed = parser.parse_args(
        rewrite_local_path_option_values(args, {"--manifest"})
    )
    target = resolve_target(parsed.target)
    remote_app_root = PurePosixPath(parsed.remote_app_root)
    app_name = resolve_uninstall_app_name(parsed.appName, parsed.manifest)
    remote_apps = read_remote_app_inventory(target, remote_app_root)

    install_dir: PurePosixPath | None = None
    for remote_app in remote_apps:
        remote_name = remote_app.get("appName")
        if remote_name != app_name:
            continue
        install_dir_text = remote_app.get("installDir")
        if isinstance(install_dir_text, str) and install_dir_text != "":
            install_dir = PurePosixPath(install_dir_text)
            break
    if install_dir is None:
        parser.error(f"app is not installed on target: {app_name}")
        raise AssertionError("unreachable")

    print(
        "Warning: if the app is currently running, Epiphany or the target runtime "
        "may still need restart or refresh after uninstall.",
        file=sys.stderr,
    )
    command = [*SSH_BASE_ARGS, target, f"rm -rf {shlex.quote(str(install_dir))}"]
    return run_commands([command], parsed.dry_run)


def dispatch_app(args: Sequence[str]) -> int:
    """Dispatch the `app` workflow area.

    Purpose:
        Provides the shared command family for idempotent app installation while
        allowing headless and Flutter flows to diverge internally.
    Parameters:
        args: Remaining command-line arguments after `app`.
    Return value:
        Exit code from the selected app workflow, or `2` for invalid usage.
    Requirements:
        None.
    Guarantees:
        `app install ...`, `app install-updated ...`, and `app uninstall ...`
        are routed to the appropriate implementations.
    Invariants:
        Unsupported app subcommands do not silently fall through.
    """

    if is_help_request(args):
        print_app_help()
        return 0
    if EXPORTED_SDK:
        print(exported_sdk_v1_message("app", args), file=sys.stderr)
        return 2
    if args[0] != "install":
        if args[0] == "install-updated":
            return dispatch_app_install_updated(args[1:])
        if args[0] == "uninstall":
            return dispatch_app_uninstall(args[1:])
        print(f"Unsupported app command: {args[0]}", file=sys.stderr)
        print_app_help()
        return 2
    if len(args) == 1:
        print("Usage: dogpaw app install <headless|flutter> [options]", file=sys.stderr)
        return 2
    if args[1] == "headless":
        return dispatch_app_install_headless(args[2:])
    if args[1] == "flutter":
        return dispatch_app_install_flutter(args[2:])
    print(f"Unsupported app install target: {args[1]}", file=sys.stderr)
    print("Usage: dogpaw app install <headless|flutter> [options]", file=sys.stderr)
    return 2


def dispatch_debug_cxx(args: Sequence[str]) -> int:
    """Dispatch `tools/dogpaw debug cxx`.

    Purpose:
        Bridges install-aware headless app preparation with the existing
        `deploy_and_run.sh` gdbserver launcher while still supporting direct
        binary debug flows for non-app targets such as Epiphany and tests.
    Parameters:
        args: Remaining arguments after `debug cxx`.
    Return value:
        Exit code from the dry-run print path or the first failing install/launch
        command.
    Requirements:
        Caller must provide `--port` and either `--manifest` or `--binary`.
    Guarantees:
        Manifest-backed launches install the app first and then debug the
        installed bundle path. Direct-binary launches keep the existing
        deploy-and-run behavior behind the new front door.
    Invariants:
        Dry-run mode does not create, modify, or delete local or remote files.
    """

    parser = build_debug_cxx_parser()
    wrapper_args, binary_args = split_passthrough_args(args)
    wrapper_args = rewrite_local_path_option_values(
        wrapper_args,
        {"--manifest", "--binary", "--build-dir", "--sync", "-s", "--sync-asset"},
    )
    parsed = parser.parse_args(wrapper_args)

    if parsed.manifest is None and parsed.binary is None:
        parser.error("either --manifest or --binary is required")
    if parsed.manifest is not None and (len(parsed.sync) > 0 or len(parsed.sync_asset) > 0 or parsed.asset_dest is not None):
        parser.error("--manifest mode does not support --sync, --sync-asset, or --asset-dest; use direct --binary mode for that workflow")

    target = resolve_target(parsed.target)
    commands: list[list[str]] = []

    if parsed.manifest is not None:
        manifest_path = resolve_local_cli_path(parsed.manifest)
        if not manifest_path.is_file():
            parser.error(f"manifest not found: {manifest_path}")
        manifest_payload = load_manifest_payload(manifest_path)
        app_name = require_manifest_string_field(manifest_path, manifest_payload, "name")
        executable_name = require_manifest_string_field(manifest_path, manifest_payload, "executable")
        build_dir = resolve_local_cli_path(parsed.build_dir)
        binary_path = (
            resolve_local_cli_path(parsed.binary)
            if parsed.binary is not None
            else (build_dir / "bin" / executable_name)
        )
        if not binary_path.is_file():
            parser.error(f"binary not found: {binary_path}")

        install_command = [
            str(DEPLOY_HEADLESS_APPS_TOOL),
            "--target",
            target,
            "--build-dir",
            str(build_dir),
            "--hardware-profile",
            parsed.hardware_profile,
            "--manifest",
            str(manifest_path),
        ]
        if parsed.dry_run:
            install_command.append("--dry-run")
        commands.append(install_command)

        remote_bundle_dir = PurePosixPath(parsed.remote_app_root) / app_name / "bundle"
        remote_env = append_env_if_missing(parsed.env, f"DOGPAW_APP_DIR={parsed.remote_app_root}")
        debug_command = [
            str(DEPLOY_AND_RUN_TOOL),
            "-t",
            target,
            "-p",
            parsed.port,
            "--no-deploy",
            "-d",
            str(remote_bundle_dir),
        ]
        if parsed.workdir is not None:
            debug_command.extend(["-w", parsed.workdir])
        if parsed.interactive_stdin:
            debug_command.append("--interactive-stdin")
        elif parsed.non_interactive_stdin:
            debug_command.append("--non-interactive-stdin")
        for assignment in remote_env:
            debug_command.extend(["--env", assignment])
        debug_command.append(str(binary_path))
        if len(binary_args) > 0:
            debug_command.append("--")
            debug_command.extend(binary_args)
        commands.append(debug_command)
        return run_commands(commands, parsed.dry_run)

    binary_path = resolve_local_cli_path(parsed.binary)
    if not binary_path.is_file():
        parser.error(f"binary not found: {binary_path}")

    debug_command = [
        str(DEPLOY_AND_RUN_TOOL),
        "-t",
        target,
        "-p",
        parsed.port,
    ]
    if parsed.workdir is not None:
        debug_command.extend(["-w", parsed.workdir])
    if parsed.interactive_stdin:
        debug_command.append("--interactive-stdin")
    elif parsed.non_interactive_stdin:
        debug_command.append("--non-interactive-stdin")
    for sync_path in parsed.sync:
        debug_command.extend(["-s", sync_path])
    for assignment in parsed.env:
        debug_command.extend(["--env", assignment])
    for asset_path in parsed.sync_asset:
        debug_command.extend(["--sync-asset", asset_path])
    if parsed.asset_dest is not None:
        debug_command.extend(["--asset-dest", parsed.asset_dest])
    debug_command.append(str(binary_path))
    if len(binary_args) > 0:
        debug_command.append("--")
        debug_command.extend(binary_args)
    return run_commands([debug_command], parsed.dry_run)


def dispatch_debug(args: Sequence[str]) -> int:
    """Dispatch the `debug` workflow area.

    Purpose:
        Provides the canonical top-level debug command family while preserving
        room for separate language- or runtime-specific debug flows later.
    Parameters:
        args: Remaining command-line arguments after `debug`.
    Return value:
        Exit code from the selected debug workflow, or `2` for invalid usage.
    Requirements:
        None.
    Guarantees:
        `debug cxx ...` and `debug flutter ...` route to the install-aware
        remote debug workflows for their respective runtimes.
    Invariants:
        Unsupported debug subcommands do not silently fall through.
    """

    if is_help_request(args):
        print_debug_help()
        return 0
    if EXPORTED_SDK:
        print(exported_sdk_v1_message("debug", args), file=sys.stderr)
        return 2
    if args[0] == "cxx":
        return dispatch_debug_cxx(args[1:])
    if args[0] == "flutter":
        return dispatch_debug_flutter(args[1:])
    print(f"Unsupported debug command: {args[0]}", file=sys.stderr)
    print_debug_help()
    return 2


def dispatch_emulator(args: Sequence[str]) -> int:
    """Dispatch the `emulator` workflow area.

    Purpose:
        Makes the existing emulator tool discoverable from the canonical top
        level while preserving its current command contract during Phase 0.
    Parameters:
        args: Remaining command-line arguments after `emulator`.
    Return value:
        Exit code from the delegated emulator tool.
    Requirements:
        `EMULATOR_TOOL` must exist and the current Python interpreter must be
        able to execute it.
    Guarantees:
        All remaining arguments pass through unchanged to the existing emulator
        CLI. With no extra args, the delegated tool uses its own default `run`
        behavior.
    Invariants:
        This dispatcher does not reimplement emulator argument parsing.
    """

    if len(args) > 0 and args[0] in ("-h", "--help", "help"):
        print_emulator_help()
        return 0
    delegated_args = list(args)
    if not EXPORTED_SDK:
        delegated_args = with_source_emulator_defaults(delegated_args)
    return run_external([sys.executable, str(EMULATOR_TOOL), *delegated_args])


def dispatch(area: str, args: Sequence[str]) -> int:
    """Dispatch one top-level workflow area.

    Purpose:
        Keeps `main()` small and makes the command-routing rules explicit and
        testable as later phases land.
    Parameters:
        area: Selected top-level workflow area.
        args: Remaining arguments for that workflow area.
    Return value:
        Exit code from the selected workflow implementation.
    Requirements:
        `area` must be one of the parser-declared workflow choices.
    Guarantees:
        Implemented areas delegate to their backing tools or built-in workflow
        logic, while not-yet-implemented areas fail with an actionable error.
    Invariants:
        Unsupported workflow areas never silently fall through.
    """

    if area == "target":
        return dispatch_target(args)
    if area == "app":
        return dispatch_app(args)
    if area == "debug":
        return dispatch_debug(args)
    if area == "emulator":
        return dispatch_emulator(args)
    if EXPORTED_SDK and area == "local":
        print(exported_sdk_v1_message(area, args), file=sys.stderr)
        return 2
    print(unimplemented_message(area, args), file=sys.stderr)
    return 2


def main(argv: Sequence[str] | None = None) -> int:
    """Run the Dog Paw workflow dispatcher.

    Purpose:
        Serves as the single user-facing CLI front door under `tools/` while
        later phases progressively replace scattered scripts with named
        workflows.
    Parameters:
        argv: Optional argument sequence excluding the program name.
    Return value:
        Process exit code.
    Requirements:
        Caller must pass arguments compatible with `build_parser()`.
    Guarantees:
        With no workflow area, prints help and exits successfully. Implemented
        areas delegate to current backing tools or built-in workflow logic;
        placeholder areas return a clear non-zero error.
    Invariants:
        Dispatcher startup itself does not mutate repository state.
    """

    parser = build_parser()
    args = parser.parse_args(argv)
    if args.area is None:
        parser.print_help()
        return 0
    if args.area not in WORKFLOW_AREAS:
        print(f"Unsupported workflow area: {args.area}", file=sys.stderr)
        parser.print_help(sys.stderr)
        return 2
    return dispatch(args.area, args.args)


if __name__ == "__main__":
    sys.exit(main())
