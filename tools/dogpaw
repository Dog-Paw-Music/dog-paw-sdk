def dispatch_emulator(args: Sequence[str]) -> int:
    """Dispatch the `emulator` workflow area.

    Purpose:
        Makes the existing emulator tool discoverable from the canonical top
        level while preserving its current command contract during Phase 0.
    Parameters:
        args: Remaining command-line arguments after `emulator`.
    Return value:
        Exit code from the delegated emulator tool.
    Requirements:
        `EMULATOR_TOOL` must exist and the current Python interpreter must be
        able to execute it.
    Guarantees:
        All remaining arguments pass through unchanged to the existing emulator
        CLI. With no extra args, the delegated tool uses its own default `run`
        behavior.
    Invariants:
        This dispatcher does not reimplement emulator argument parsing.
    """

    if len(args) > 0 and args[0] in ("-h", "--help", "help"):
        print_emulator_help()
        return 0
    delegated_args = list(args)
    if not EXPORTED_SDK:
        delegated_args = with_source_emulator_defaults(delegated_args)
    return run_external([sys.executable, str(EMULATOR_TOOL), *delegated_args])


def dispatch(area: str, args: Sequence[str]) -> int:
    """Dispatch one top-level workflow area.

    Purpose:
        Keeps `main()` small and makes the command-routing rules explicit and
        testable as later phases land.
    Parameters:
        area: Selected top-level workflow area.
        args: Remaining arguments for that workflow area.
    Return value:
        Exit code from the selected workflow implementation.
    Requirements:
        `area` must be one of the parser-declared workflow choices.
    Guarantees:
        Implemented areas delegate to their backing tools or built-in workflow
        logic, while not-yet-implemented areas fail with an actionable error.
    Invariants:
        Unsupported workflow areas never silently fall through.
    """

    if area == "target":
        return dispatch_target(args)
    if area == "app":
        return dispatch_app(args)
    if area == "debug":
        return dispatch_debug(args)
    if area == "emulator":
        return dispatch_emulator(args)
    if EXPORTED_SDK and area == "local":
        print(exported_sdk_v1_message(area, args), file=sys.stderr)
        return 2
    print(unimplemented_message(area, args), file=sys.stderr)
    return 2


def main(argv: Sequence[str] | None = None) -> int:
    """Run the Dog Paw workflow dispatcher.

    Purpose:
        Serves as the single user-facing CLI front door under `tools/` while
        later phases progressively replace scattered scripts with named
        workflows.
    Parameters:
        argv: Optional argument sequence excluding the program name.
    Return value:
        Process exit code.
    Requirements:
        Caller must pass arguments compatible with `build_parser()`.
    Guarantees:
        With no workflow area, prints help and exits successfully. Implemented
        areas delegate to current backing tools or built-in workflow logic;
        placeholder areas return a clear non-zero error.
    Invariants:
        Dispatcher startup itself does not mutate repository state.
    """

    parser = build_parser()
    args = parser.parse_args(argv)
    if args.area is None:
        parser.print_help()
        return 0
    if args.area not in WORKFLOW_AREAS:
        print(f"Unsupported workflow area: {args.area}", file=sys.stderr)
        parser.print_help(sys.stderr)
        return 2
    return dispatch(args.area, args.args)


if __name__ == "__main__":
    sys.exit(main())
