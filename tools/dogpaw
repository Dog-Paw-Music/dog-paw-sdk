def build_remote_flutter_stop_command(
    context: FlutterManifestContext,
    remote_source_root: PurePosixPath,
    remote_port: str,
) -> str:
    """Build the remote stop command for one Flutter debug session.

    Purpose:
        Stops a previously launched remote Flutter debug session by killing the
        VM service listener on the fixed debug port and any matching debug bundle
        executable that may still be running after detach.
    Parameters:
        context: Resolved Flutter manifest context.
        remote_source_root: Remote temporary Flutter workspace source root used by the
            debug workflow.
        remote_port: Fixed remote Dart VM service TCP port for this debug session.
    Return value:
        One shell command string suitable for execution over SSH.
    Requirements:
        `remote_port` must be a non-empty TCP port string.
    Guarantees:
        The command is idempotent and succeeds even when no matching process is
        currently running.
    Invariants:
        Only the requested port and the matching app bundle executable are
        targeted for termination.
    """

    remote_paths = build_flutter_remote_paths(context, remote_source_root)
    remote_project_dir = remote_paths["remote_flutter_project_dir"]
    remote_bundle_pattern = shlex.quote(
        f"{remote_project_dir}/build/linux/.*/debug/bundle/{context.flutter_project_rel}"
    )
    return (
        f"fuser -k {shlex.quote(remote_port)}/tcp >/dev/null 2>&1 || true; "
        f"pkill -f {remote_bundle_pattern} >/dev/null 2>&1 || true; "
        "true"
    )


def build_flutter_install_parser() -> argparse.ArgumentParser:
    """Build the parser for `tools/dogpaw app install flutter`.

    Purpose:
        Defines the host-side remote Flutter install contract while keeping the
        top-level dispatcher small and testable.
    Parameters:
        None.
    Return value:
        Configured parser for the Flutter remote install flow.
    Requirements:
        None.
    Guarantees:
        Required arguments and repository-root defaults are encoded in one
        parser instance.
    Invariants:
        Parser construction performs no filesystem or network I/O.
    """

    parser = argparse.ArgumentParser(
        prog="dogpaw app install flutter",
        description="Sync one Flutter app to a Pi, build it there, and install it into the Dog Paw app registry.",
    )
    parser.add_argument("--manifest", required=True, help="Path to the Flutter app dogpawapp.json.")
    parser.add_argument("--target", help="Remote SSH target. Defaults to local_config.sh --target.")
    parser.add_argument(
        "--remote-source-root",
        default=str(REMOTE_SOURCE_ROOT),
        help="Remote temporary Flutter workspace source root used for synced Flutter app builds.",
    )
    parser.add_argument(
        "--remote-app-root",
        default=str(REMOTE_APP_ROOT),
        help="Remote Dog Paw installed-app root.",
    )
    parser.add_argument(
        "--remote-flutter-root",
        default=str(REMOTE_FLUTTER_ROOT),
        help="Remote Flutter SDK root whose bin directory will be added to PATH.",
    )
    parser.add_argument(
        "--bridge-lib",
        default="/home/dppi/libs/libdogpaw_bridge.so",
        help="Remote dogpaw bridge library path required by installed Flutter apps.",
    )
    parser.add_argument("--build-mode", default="release", help="Flutter Linux build mode.")
    parser.add_argument("--dry-run", action="store_true", help="Print sync/build commands without executing them.")
    return parser


def dispatch_target(args: Sequence[str]) -> int:
    """Dispatch the `target` workflow area.

    Purpose:
        Provides the canonical top-level entrypoint for Pi target setup while
        temporarily delegating the real work to the existing bootstrap tool.
    Parameters:
        args: Remaining command-line arguments after `target`.
    Return value:
        Exit code from the delegated bootstrap flow, or `2` for invalid target
        subcommand usage.
    Requirements:
        `BOOTSTRAP_TOOL` must exist and be executable for delegation to succeed.
    Guarantees:
        `target apply ...` maps directly onto the current bootstrap command
        without rewriting the bootstrap-specific options.
    Invariants:
        This dispatcher does not implement bootstrap logic itself.
    """

    if is_help_request(args):
        print_target_help()
        return 0
    if EXPORTED_SDK:
        print(exported_sdk_v1_message("target", args), file=sys.stderr)
        return 2
    if args[0] != "apply":
        print(f"Unsupported target command: {args[0]}", file=sys.stderr)
        print_target_help()
        return 2
    apply_args = rewrite_local_path_option_values(
        args[1:],
        {"--identity-file"},
    )
    return run_external([str(BOOTSTRAP_TOOL), *apply_args])


def dispatch_app_install_headless(args: Sequence[str]) -> int:
    """Dispatch `tools/dogpaw app install headless`.

    Purpose:
        Reuses the existing remote headless-app deployment tool behind the new
        workflow surface instead of reimplementing manifest staging logic.
    Parameters:
