def build_parser() -> argparse.ArgumentParser:
    """Build the top-level Dog Paw workflow parser.

    Purpose:
        Defines the single user-facing command surface under `tools/` for Dog
        Paw workflows that span Pi setup, app installation, remote debugging,
        and emulator management.
    Parameters:
        None.
    Return value:
        Configured parser that accepts one workflow area plus pass-through
        trailing arguments for area-specific dispatch.
    Requirements:
        None.
    Guarantees:
        Help output names the supported workflow areas and explains that deeper
        scripts are implementation details behind this dispatcher.
    Invariants:
        Parser construction does not inspect the filesystem or launch external
        commands.
    """

    parser = argparse.ArgumentParser(
        prog="dogpaw",
        description="Dog Paw workflow front door.",
        epilog=(
            "Start here:\n"
            "  dogpaw emulator --help\n"
            "  dogpaw emulator run --help\n"
            "  dogpaw emulator screen --help\n"
            "  dogpaw emulator logs --name default"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "area",
        nargs="?",
        metavar="area",
        help=(
            "Workflow area. Primary v1 areas: "
            f"{', '.join(TOP_LEVEL_HELP_AREAS)}."
        ),
    )
    parser.add_argument(
        "args",
        nargs=argparse.REMAINDER,
        help="Arguments passed to the selected workflow area.",
    )
    return parser


def shell_join(words: Sequence[str]) -> str:
    """Render shell-safe text for one command line.

    Purpose:
        Produces readable dry-run command lines while preserving argument
        boundaries for paths and flags that contain spaces or punctuation.
    Parameters:
        words: Command words in execution order.
    Return value:
        POSIX-shell-quoted command string.
    Requirements:
        Each item in `words` must already be the intended literal token.
    Guarantees:
        Returned text preserves original token boundaries when pasted into a
        POSIX shell.
    Invariants:
        Does not inspect the filesystem or mutate process state.
    """

    return " ".join(shlex.quote(word) for word in words)


def run_external(command: Sequence[str]) -> int:
    """Run one external command and return its exit code.

    Purpose:
        Centralizes subprocess launching so workflow dispatch remains explicit
        while preserving the caller's original shell working directory for
        relative local path arguments.
    Parameters:
        command: Executable path plus arguments for the delegated tool.
    Return value:
        Exit code from the delegated process.
    Requirements:
        `command` must contain at least one element and the executable must be
        runnable by the current environment.
    Guarantees:
        Child stdout and stderr stream directly through this process, and the
        child runs with the user's invocation directory as its current working
        directory.
    Invariants:
        This helper does not rewrite arguments or mutate repository files by
        itself; any side effects come only from the delegated tool.
    """

    completed = subprocess.run(command, cwd=INVOCATION_CWD, check=False)
    return int(completed.returncode)


def load_repo_only_workspace_helper():
    """Load the repo-only path helper used by non-exported workflows.

    Purpose:
        Keeps source-checkout layout knowledge out of the exported public
        `dogpaw` script while still letting Pi deployment and refresh workflows
        resolve their repo-only manifest and resource roots when running from the
        main development checkout.
    Parameters:
        None.
    Return value:
        Imported helper module object that exposes repo-only path builders.
    Requirements:
        The main development checkout must include `tools/dogpaw_repo_layout.py`.
    Guarantees:
        Raises a clear runtime error instead of silently guessing paths when the
        repo-only helper is unavailable.
    Invariants:
        Does not create files or mutate repository state.
    """

    helper_path = DOGPAW_TOOL_PATH.parent / "dogpaw_repo_layout.py"
    if not helper_path.is_file():
        raise RuntimeError(
            "Repo-only Dog Paw workspace helpers are unavailable in this checkout."
        )
    module_name = "dogpaw_repo_layout"
    spec = importlib.util.spec_from_file_location(module_name, helper_path)
    if spec is None or spec.loader is None:
        raise RuntimeError(f"Could not load repo-only workspace helper: {helper_path}")
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


def load_install_support_modules():
    """Load install helper modules from the configured helper-tools directory.

    Purpose:
        Defers import of repo-local install helpers so exported SDK workflows can
        reject unsupported non-emulator commands cleanly even when those helper
        modules are absent from a reduced public checkout.
    Parameters:
        None.
    Return value:
        Tuple of `(install_app_module, install_fingerprint_module)` loaded from
        `INSTALL_SUPPORT_TOOLS_ROOT`.
    Requirements:
        `INSTALL_SUPPORT_TOOLS_ROOT` must contain importable `install_app.py` and
        `install_fingerprint.py` files when a workflow reaches helper-backed
        install logic.
    Guarantees:
        Raises a clear runtime error instead of failing with a generic import
        stack trace when helper modules are missing.
    Invariants:
        Loads helper code only; does not mutate repository files or CLI state.
    """

    module_names = ("install_app", "install_fingerprint")
    loaded_modules = []
    for module_name in module_names:
        module_path = INSTALL_SUPPORT_TOOLS_ROOT / f"{module_name}.py"
        if not module_path.is_file():
            raise RuntimeError(
                "Dog Paw install-support helpers are unavailable in this checkout: "
                f"{module_path}"
            )
        spec = importlib.util.spec_from_file_location(module_name, module_path)
        if spec is None or spec.loader is None:
            raise RuntimeError(f"Could not load Dog Paw helper module: {module_path}")
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        loaded_modules.append(module)
    return tuple(loaded_modules)


def is_help_request(args: Sequence[str]) -> bool:
    """Return whether one argument list only asks for help text.

    Purpose:
        Lets exported-SDK gating preserve command discovery while still failing
        unsupported workflow execution from the public CLI surface.
    Parameters:
        args: Remaining command arguments after one workflow selector.
    Return value:
        `True` when the arguments are empty or begin with a standard help token.
    Requirements:
        `args` must preserve the user's original argument order.
    Guarantees:
        Recognizes `-h`, `--help`, and `help`.
    Invariants:
        Does not inspect the filesystem or mutate process state.
    """

    return len(args) == 0 or args[0] in ("-h", "--help", "help")


def args_include_option(args: Sequence[str], option_names: set[str]) -> bool:
    """Return whether one argument list already supplies any named option.

    Purpose:
        Lets wrapper dispatch add source-repo convenience defaults only when the
        user did not already make an explicit choice.
    Parameters:
        args: Raw delegated argument sequence.
        option_names: Long or short option spellings to detect.
    Return value:
        `True` when `args` contains one of the options, including `--opt=value`
        forms.
    Requirements:
        `option_names` should contain canonical option spellings.
    Guarantees:
        Stops scanning at a literal `--` separator.
    Invariants:
        Does not resolve paths or mutate the input sequence.
    """

    for token in args:
        if token == "--":
            return False
        if token in option_names:
            return True
        if any(token.startswith(f"{option_name}=") for option_name in option_names):
            return True
    return False


def with_source_emulator_defaults(args: Sequence[str]) -> list[str]:
    """Inject source-checkout emulator defaults when the user omitted them.

    Purpose:
        Preserves convenient local dev-repo emulator workflows while the public
        `dogpaw_emulator.py` stays portable and exported-SDK-safe.
    Parameters:
        args: Raw emulator arguments after the top-level `emulator` selector.
    Return value:
        Argument list extended with source-repo `--epiphany` and `--build-dir`
        defaults when needed.
    Requirements:
        `args` must preserve the user's original argument order.
    Guarantees:
        Explicit user-supplied `--epiphany` or `--build-dir` values win.
    Invariants:
        Exported SDK dispatch does not use these source-repo defaults.
    """

    rewritten_args = list(args)
    if not args_include_option(rewritten_args, {"--epiphany"}):
        rewritten_args.extend(["--epiphany", str(DEFAULT_EMULATOR_EPIPHANY)])
    if not args_include_option(rewritten_args, {"--build-dir"}):
        rewritten_args.extend(["--build-dir", str(DEFAULT_EMULATOR_BUILD_DIR)])
    return rewritten_args


def exported_sdk_v1_message(area: str, args: Sequence[str]) -> str:
    """Build the exported-SDK error for unsupported non-emulator workflows.

    Purpose:
        Gives the generated public SDK one intentional failure mode for workflow
        families that still depend on internal Pi-repo tooling outside the
        agreed emulator-first v1 surface.
    Parameters:
        area: Top-level workflow area that the user selected.
        args: Remaining arguments after that workflow area.
    Return value:
        Human-readable stderr message for the unsupported exported command.
    Requirements:
        `area` must name a workflow area shown by the top-level parser.
    Guarantees:
        The returned text explains that the exported SDK currently supports only
        emulator-first workflows and points users at the public emulator surface.
    Invariants:
        Does not inspect the filesystem or mutate global state.
    """

    attempted = f"{area} {' '.join(args)}".strip()
    return (
        f"'dogpaw {attempted}' is not supported in exported SDK v1.\n"
        "Exported SDK v1 currently supports the emulator-first workflow surface:\n"
        "  dogpaw emulator create ...\n"
        "  dogpaw emulator run ...\n"
        "  dogpaw emulator screen ...\n"
        "  dogpaw emulator install-flutter ...\n"
        "  dogpaw emulator install-headless ...\n"
        "  dogpaw emulator logs ...\n"
        "  dogpaw emulator doctor ..."
    )


def validate_tcp_port_text(port_text: str, option_name: str) -> int:
    """Parse and validate one TCP port option value.

    Purpose:
        Gives remote-debug workflows one shared validation path for user-supplied
        TCP port strings before they are used for local binds, SSH forwards, or
        remote `flutter run` arguments.
    Parameters:
        port_text: Decimal TCP port string from CLI input.
        option_name: Human-readable option name used in validation errors.
    Return value:
        Parsed integer TCP port.
    Requirements:
        `port_text` must be a base-10 integer in the TCP port range.
    Guarantees:
        Raises `ValueError` when the port is invalid.
    Invariants:
        Does not bind, reserve, or mutate any socket state.
    """

    try:
        port = int(port_text)
    except ValueError as exc:
        raise ValueError(f"invalid TCP port for {option_name}: {port_text}") from exc
    if port < 1 or port > 65535:
        raise ValueError(f"invalid TCP port for {option_name}: {port_text}")
    return port


def ensure_local_tcp_port_available(port_text: str) -> None:
    """Fail when the requested localhost TCP port is already occupied.

    Purpose:
        Prevents long remote sync/build work from starting when a static debug
        attach port is already held by another local tunnel or process.
    Parameters:
        port_text: Decimal TCP port string from CLI input.
    Return value:
        None.
    Requirements:
        `port_text` must parse as an integer in the TCP port range.
    Guarantees:
        Raises `ValueError` when the port is invalid or currently unavailable.
    Invariants:
        Leaves the port unbound after a successful check.
    """

    port = validate_tcp_port_text(port_text, "--local-port")
    probe = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        probe.bind(("127.0.0.1", port))
    except OSError as exc:
        raise ValueError(f"local port already in use: {port}") from exc
    finally:
        probe.close()


def choose_available_local_tcp_port() -> str:
    """Allocate one currently free localhost TCP port number.

    Purpose:
        Lets IDE-driven Flutter attach flows avoid brittle fixed local forward
        ports by selecting a fresh ephemeral port for each launch.
    Parameters:
        None.
    Return value:
        Decimal TCP port string that was free at selection time.
    Requirements:
        The local machine must permit binding an ephemeral localhost TCP port.
    Guarantees:
        Returns a syntactically valid TCP port string.
    Invariants:
        The helper releases the probe socket before returning, so the port is
        not reserved after selection.
    """

    probe = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        probe.bind(("127.0.0.1", 0))
        return str(probe.getsockname()[1])
    finally:
        probe.close()


def remove_file_if_exists(path: Path) -> None:
    """Delete one local file when it already exists.

    Purpose:
        Prevents stale Flutter attach metadata files from leaking an old VM
        service URI into a new launch attempt.
    Parameters:
        path: File path to remove if present.
    Return value:
        None.
    Requirements:
        `path` points to the local filesystem.
    Guarantees:
        Missing files are ignored without error.
    Invariants:
        Parent directories are not removed.
    """

    try:
        path.unlink()
    except FileNotFoundError:
        return


def write_flutter_service_info_file(path: Path, uri: str) -> None:
    """Write Dart/Flutter attach metadata for file-driven IDE attach.

    Purpose:
        Bridges custom `tools/dogpaw debug flutter` launches to the Dart debug
        adapter by materializing the selected forwarded localhost VM service URI
        in the JSON shape currently used by this workflow.
    Parameters:
        path: Local file path the IDE will poll.
        uri: Local VM service websocket URI exposed through the SSH tunnel.
    Return value:
        None.
    Requirements:
        `uri` must be a valid websocket URI reachable from the local machine.
    Guarantees:
        Parent directories are created and the file is replaced for the current
        launch attempt.
    Invariants:
        The JSON payload always contains exactly one top-level `uri` field.
    """

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps({"uri": uri}), encoding="utf-8")


def stream_flutter_debug_launch(
    launch_command: Sequence[str],
    local_port: str,
    service_info_file: Path | None,
) -> int:
    """Run the long-lived Flutter SSH tunnel and stream its output.

    Purpose:
        Keeps the remote `flutter run` session alive for IDE attach while
        translating the remote ready signal into a local `vmServiceInfoFile`
        update once the forwarded tunnel is actually the intended attach target.
    Parameters:
        launch_command: SSH command that owns both the port forward and the
            remote Flutter process lifecycle.
        local_port: Selected localhost port exposed to the IDE.
        service_info_file: Optional local metadata file to write when the VM
            service becomes attach-ready.
    Return value:
        Child process exit code.
    Requirements:
        `launch_command` must be executable and produce readiness output on
        stdout or stderr.
    Guarantees:
        Child output is relayed to stdout, stale service-info files are cleared
        before launch, and termination signals are forwarded to the SSH process
        group.
    Invariants:
        The helper never writes service-info metadata before the remote launch
        reports `Flutter VM service ready: ...`.
    """

    if service_info_file is not None:
        remove_file_if_exists(service_info_file)
    process = subprocess.Popen(
        list(launch_command),
        cwd=INVOCATION_CWD,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
        start_new_session=True,
    )
    original_handlers: dict[int, object] = {}

    def forward_signal_to_child(signum: int, _frame: object) -> None:
        if process.poll() is None:
            try:
                os.killpg(process.pid, signum)
            except ProcessLookupError:
                pass

    for signal_name in ("SIGINT", "SIGTERM", "SIGHUP"):
        if hasattr(signal, signal_name):
            signum = getattr(signal, signal_name)
            original_handlers[signum] = signal.getsignal(signum)
            signal.signal(signum, forward_signal_to_child)

    wrote_service_info = False
    local_vmservice_uri = f"ws://127.0.0.1:{local_port}/ws"
    try:
        if process.stdout is not None:
            for raw_line in process.stdout:
                print(raw_line, end="", flush=True)
                if (
                    service_info_file is not None
                    and not wrote_service_info
                    and raw_line.startswith("Flutter VM service ready: ")
                ):
                    write_flutter_service_info_file(
                        service_info_file,
                        local_vmservice_uri,
                    )
                    print(
                        f"Flutter attach metadata ready: {local_vmservice_uri}",
                        flush=True,
                    )
                    wrote_service_info = True
        return int(process.wait())
    finally:
        for signum, handler in original_handlers.items():
            signal.signal(signum, handler)
        if service_info_file is not None and not wrote_service_info:
            remove_file_if_exists(service_info_file)
        if process.poll() is None:
            try:
                os.killpg(process.pid, signal.SIGTERM)
            except ProcessLookupError:
                pass
            try:
                process.wait(timeout=5)
            except subprocess.TimeoutExpired:
                try:
                    os.killpg(process.pid, signal.SIGKILL)
                except ProcessLookupError:
                    pass
                process.wait(timeout=5)


def run_commands(commands: Sequence[Sequence[str]], dry_run: bool) -> int:
    """Run a sequence of external commands or print them for dry-run mode.

    Purpose:
        Keeps multi-step workflow implementations consistent across dry-run and
        real execution modes.
    Parameters:
        commands: Ordered command vectors to print or execute.
        dry_run: When true, print the commands instead of executing them.
    Return value:
        `0` when all commands succeed or when dry-run printing completes;
        otherwise the first failing command's exit code.
    Requirements:
        Each command vector must contain at least one token.
    Guarantees:
        Commands run in order from the user's invocation directory. Dry-run mode
        emits one shell-safe line per command.
    Invariants:
        This helper does not mutate command contents between print and execute
        paths.
    """

    for command in commands:
        if dry_run:
            print(shell_join(command))
            continue
        exit_code = run_external(command)
        if exit_code != 0:
            return exit_code
    return 0


def run_json_command(command: Sequence[str]) -> dict[str, object]:
    """Run one command that must return a JSON object on stdout.

    Purpose:
        Provides one place for remote-inspection helpers to execute commands and
        validate the JSON payload shape before planning logic consumes it.
    Parameters:
        command: External command vector whose stdout should contain JSON.
    Return value:
        Parsed JSON object from stdout.
    Requirements:
        The command exits successfully and writes one JSON object to stdout.
    Guarantees:
        Raises `RuntimeError` with stderr details on command or JSON failures.
    Invariants:
        Does not mutate the command vector or global process state.
    """

    completed = subprocess.run(
        command,
        cwd=INVOCATION_CWD,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if completed.returncode != 0:
        raise RuntimeError(completed.stderr.strip() or shell_join(command))
    try:
        payload = json.loads(completed.stdout)
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"command did not return valid JSON: {shell_join(command)}") from exc
    if not isinstance(payload, dict):
        raise RuntimeError(f"command did not return a JSON object: {shell_join(command)}")
    return payload


def resolve_local_cli_path(path_text: str) -> Path:
    """Resolve one local CLI path argument from the invocation directory.
    
    Purpose:
        Keeps local file and directory arguments consistent whether `dogpaw` is
        launched as `./tools/dogpaw` from the repo root or via a PATH entry from
        some other directory.
    Parameters:
        path_text: User-provided local path argument. May be absolute, relative,
            or start with `~`.
    Return value:
        Absolute normalized local filesystem path.
    Requirements:
        `path_text` names a local path, not a remote target path on the Pi.
    Guarantees:
        Relative paths are anchored at the user's original invocation directory,
        not at the repository root or any delegated tool directory.
    Invariants:
        Path resolution is pure; it does not create files or directories.
    """

    local_path = Path(path_text).expanduser()
    if not local_path.is_absolute():
        local_path = INVOCATION_CWD / local_path
    return local_path.resolve()


def rewrite_local_path_option_values(
    args: Sequence[str],
    local_path_options: set[str],
) -> list[str]:
    """Rewrite selected option values to absolute local paths.

    Purpose:
        Normalizes delegated-tool arguments whose values refer to local files or
        directories so the effective path semantics stay tied to the user's
        invocation directory and dry-run output matches real execution.
    Parameters:
        args: Raw option sequence to rewrite.
        local_path_options: Option names whose next token, or `--opt=value`
            payload, should be treated as a local path.
    Return value:
        New argument list with matching local path option values rewritten to
        absolute paths.
    Requirements:
        `local_path_options` must contain only options whose values are local
        filesystem paths. Remote Pi paths must not be included.
    Guarantees:
        Argument order is preserved. Tokens after a literal `--` separator are
        left untouched.
    Invariants:
        Does not inspect or mutate tokens for options outside
        `local_path_options`.
    """

    rewritten_args: list[str] = []
    index = 0
    while index < len(args):
        token = args[index]
        if token == "--":
            rewritten_args.extend(args[index:])
            break

        matched_inline_option = False
        for option_name in local_path_options:
            inline_prefix = f"{option_name}="
            if token.startswith(inline_prefix):
                resolved_value = resolve_local_cli_path(token[len(inline_prefix) :])
                rewritten_args.append(f"{option_name}={resolved_value}")
                matched_inline_option = True
                break
        if matched_inline_option:
            index += 1
            continue

        rewritten_args.append(token)
        if token in local_path_options and index + 1 < len(args):
            rewritten_args.append(str(resolve_local_cli_path(args[index + 1])))
            index += 2
            continue
        index += 1

    return rewritten_args


def resolve_target(explicit_target: str | None) -> str:
    """Resolve the SSH target for remote workflows.

    Purpose:
        Keeps target lookup consistent across remote install and setup commands
        by honoring an explicit flag first, then the existing local config
        helper, then a final repository default.
    Parameters:
        explicit_target: User-supplied SSH target, or `None`.
    Return value:
        SSH target string in `user@host` form.
    Requirements:
        None.
    Guarantees:
        Returns a non-empty target string when local config lookup succeeds or
        when the built-in fallback is used.
    Invariants:
        Does not persist configuration changes.
    """

    if explicit_target is not None and explicit_target != "":
        return explicit_target
    if LOCAL_CONFIG_TOOL.is_file() and LOCAL_CONFIG_TOOL.stat().st_mode & 0o111:
        completed = subprocess.run(
            [str(LOCAL_CONFIG_TOOL), "--target"],
            cwd=WORKSPACE_ROOT,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )
        if completed.returncode == 0:
            resolved = completed.stdout.strip()
            if resolved != "":
                return resolved
    return "dppi@dogpaw"


def read_remote_target_hardware_profile(
    target: str,
    remote_script_dir: PurePosixPath,
) -> str | None:
    """Read the installed Dog Paw hardware profile name from one target.

    Purpose:
        Implements the install-updated hardware-profile safety gate without
        assuming shell sourcing on the remote host.
    Parameters:
        target: SSH target in `user@host` form.
        remote_script_dir: Remote Dog Paw script root.
    Return value:
        Installed hardware profile string, or `None` when the generated file is
        missing or does not declare `DOGPAW_HW_PROFILE`.
    Requirements:
        SSH access to `target` works with the standard Dog Paw remote
        environment.
    Guarantees:
        Reads only the generated hardware-profile file.
    Invariants:
        Does not modify remote files.
    """

    remote_profile_path = remote_script_dir / "generated" / "hardware_profile.sh"
    command = [
        *SSH_BASE_ARGS,
        target,
        (
            "python3 -c "
            + shlex.quote(
                "from pathlib import Path\n"
                "import re\n"
                f"path = Path({str(remote_profile_path)!r})\n"
                "if not path.is_file():\n"
                "    print('{\"targetHardwareProfile\": null}')\n"
                "else:\n"
                "    match = re.search(r'^export DOGPAW_HW_PROFILE=\"?([^\"\\n]+)\"?$', path.read_text(encoding=\"utf-8\"), re.M)\n"
                "    value = match.group(1) if match else None\n"
                "    import json\n"
                "    print(json.dumps({'targetHardwareProfile': value}))\n"
            )
        ),
    ]
    payload = run_json_command(command)
    value = payload.get("targetHardwareProfile")
    return value if isinstance(value, str) and value != "" else None


def read_remote_app_inventory(
    target: str,
    remote_app_root: PurePosixPath,
) -> list[dict[str, object]]:
    """Read installed app inventory from one remote Dog Paw app registry.

    Purpose:
        Enumerates installed app directories on the target and collects the
        minimal metadata needed for install-updated planning.
    Parameters:
        target: SSH target in `user@host` form.
        remote_app_root: Remote Dog Paw installed-app root.
    Return value:
        Ordered list of installed-app inventory dictionaries.
    Requirements:
        SSH access to `target` works and the remote host has Python 3.
    Guarantees:
        Includes app directory path, recoverable app name, and parsed install
        metadata when present.
    Invariants:
        Does not mutate remote installed apps.
    """

    remote_command = (
        "python3 -c "
        + shlex.quote(
            "from pathlib import Path\n"
            "import json\n"
            f"app_root = Path({str(remote_app_root)!r})\n"
            "apps = []\n"
            "if app_root.is_dir():\n"
            "    for child in sorted(app_root.iterdir()):\n"
            "        if not child.is_dir():\n"
            "            continue\n"
            "        app_name = None\n"
            "        manifest_path = child / 'dogpawapp.json'\n"
            "        metadata_path = child / 'install_metadata.json'\n"
            "        metadata = None\n"
            "        if manifest_path.is_file():\n"
            "            try:\n"
            "                manifest = json.loads(manifest_path.read_text(encoding='utf-8'))\n"
            "            except Exception:\n"
            "                manifest = None\n"
            "            if isinstance(manifest, dict):\n"
            "                name = manifest.get('name')\n"
            "                if isinstance(name, str) and name != '':\n"
            "                    app_name = name\n"
            "        if metadata_path.is_file():\n"
            "            try:\n"
            "                metadata = json.loads(metadata_path.read_text(encoding='utf-8'))\n"
            "            except Exception:\n"
            "                metadata = None\n"
            "            if app_name is None and isinstance(metadata, dict):\n"
            "                meta_name = metadata.get('appName')\n"
            "                if isinstance(meta_name, str) and meta_name != '':\n"
            "                    app_name = meta_name\n"
            "        if app_name is None and not metadata_path.is_file() and not manifest_path.is_file():\n"
            "            continue\n"
            "        apps.append({'installDir': str(child), 'appName': app_name, 'metadata': metadata})\n"
            "print(json.dumps({'apps': apps}))\n"
        )
    )
    payload = run_json_command([*SSH_BASE_ARGS, target, remote_command])
    apps = payload.get("apps", [])
    return apps if isinstance(apps, list) else []


def read_remote_globals_metadata(
    target: str,
    remote_script_dir: PurePosixPath,
) -> dict[str, object] | None:
    """Read remote globals fingerprint metadata from the generated scripts area.

    Purpose:
        Lets install-updated compare the current host-side globals fingerprint
        against the last deployed value stored on the target.
    Parameters:
        target: SSH target in `user@host` form.
        remote_script_dir: Remote Dog Paw script root.
    Return value:
        Parsed metadata dictionary, or `None` when the file is missing or
        invalid.
    Requirements:
        SSH access to `target` works and the remote host has Python 3.
    Guarantees:
        Reads only the agreed globals metadata path.
    Invariants:
        Does not mutate remote files.
    """

    metadata_path = globals_metadata_remote_path(remote_script_dir)
    remote_command = (
        "python3 -c "
        + shlex.quote(
            "from pathlib import Path\n"
            "import json\n"
            f"path = Path({str(metadata_path)!r})\n"
            "payload = None\n"
            "if path.is_file():\n"
            "    try:\n"
            "        loaded = json.loads(path.read_text(encoding='utf-8'))\n"
            "    except Exception:\n"
            "        loaded = None\n"
            "    if isinstance(loaded, dict):\n"
            "        payload = loaded\n"
            "print(json.dumps({'globalsMetadata': payload}))\n"
        )
    )
    payload = run_json_command([*SSH_BASE_ARGS, target, remote_command])
    metadata = payload.get("globalsMetadata")
    return metadata if isinstance(metadata, dict) else None


def read_remote_flutter_sdk_version(
    target: str,
    remote_flutter_root: PurePosixPath,
) -> str | None:
    """Read the current Flutter SDK version string from the remote Pi.

    Purpose:
        Supports Flutter install-updated staleness checks that treat SDK version
        changes as reinstall triggers.
    Parameters:
        target: SSH target in `user@host` form.
        remote_flutter_root: Remote Flutter SDK root.
    Return value:
        First line of `flutter --version`, or `None` when Flutter is unavailable.
    Requirements:
        SSH access to `target` works.
    Guarantees:
        Returns a normalized one-line version string when the remote Flutter
        executable exists.
    Invariants:
        Does not mutate the remote Flutter installation.
    """

    remote_flutter = remote_flutter_root / "bin" / "flutter"
    remote_command = (
        f"if [[ -x {shlex.quote(str(remote_flutter))} ]]; then "
        f"{shlex.quote(str(remote_flutter))} --version | sed -n '1p'; "
        "fi"
    )
    completed = subprocess.run(
        [*SSH_BASE_ARGS, target, remote_command],
        cwd=INVOCATION_CWD,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if completed.returncode != 0:
        raise RuntimeError(completed.stderr.strip() or remote_command)
    value = completed.stdout.strip()
    return value if value != "" else None


def load_install_updated_remote_state(
    *,
    target: str,
    remote_app_root: PurePosixPath,
    remote_script_dir: PurePosixPath,
    remote_flutter_root: PurePosixPath,
) -> InstallUpdatedRemoteState:
    """Load the remote facts needed to plan one install-updated run.

    Purpose:
        Bundles the baseline target inspection steps so command dispatch can stay
        focused on planning and execution order rather than raw SSH plumbing.
    Parameters:
        target: SSH target in `user@host` form.
        remote_app_root: Remote Dog Paw installed-app root.
        remote_script_dir: Remote Dog Paw script root.
        remote_flutter_root: Remote Flutter SDK root used later if Flutter apps
            need SDK-version comparison.
    Return value:
        Immutable `InstallUpdatedRemoteState`.
    Requirements:
        SSH access to the target works.
    Guarantees:
        Populates hardware profile, installed app inventory, and globals
        metadata. Flutter SDK version remains `None` until explicitly probed.
    Invariants:
        Does not mutate target state.
    """

    return InstallUpdatedRemoteState(
        target_hardware_profile=read_remote_target_hardware_profile(target, remote_script_dir),
        remote_apps=read_remote_app_inventory(target, remote_app_root),
        globals_metadata=read_remote_globals_metadata(target, remote_script_dir),
        flutter_sdk_version=None,
    )


