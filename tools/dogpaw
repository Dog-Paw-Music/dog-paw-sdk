def unimplemented_message(area: str, args: Sequence[str]) -> str:
    """Build an actionable not-yet-implemented workflow message.

    Purpose:
        Keeps later-phase workflow placeholders explicit while pointing users at
        the supported front-door commands that already exist.
    Parameters:
        area: Top-level workflow area that was selected.
        args: Remaining arguments after the area token. The first item, when
            present, is typically the attempted subcommand.
    Return value:
        Human-readable error message for stderr.
    Requirements:
        `area` must be one of the declared workflow areas not currently
        implemented by this dispatcher.
    Guarantees:
        The returned text points users back to the current source-of-truth plan
        and at least one working workflow command.
    Invariants:
        Does not inspect the filesystem or mutate global state.
    """

    attempted = f"{area} {' '.join(args)}".strip()
    return (
        f"'dogpaw {attempted}' is not implemented yet.\n"
        f"Currently supported workflows include:\n"
        f"  dogpaw target apply ...\n"
        f"  dogpaw app install <headless|flutter> ...\n"
        f"  dogpaw debug <cxx|flutter> ...\n"
        f"  dogpaw emulator ...\n"
        f"See the current workflow plan at: {PLAN_PATH.relative_to(WORKSPACE_ROOT)}"
    )


def split_passthrough_args(args: Sequence[str]) -> tuple[list[str], list[str]]:
    """Split dispatcher arguments at the first explicit `--` separator.

    Purpose:
        Keeps wrapper option parsing independent from the remote binary's own
        arguments when subcommands need to forward trailing argv entries.
    Parameters:
        args: Raw argument sequence after a subcommand selector.
    Return value:
        Tuple of `wrapper_args` before `--` and `passthrough_args` after it.
    Requirements:
        None.
    Guarantees:
        The separator itself is omitted from both returned lists.
    Invariants:
        Returned argument order matches the input order.
    """

    if "--" not in args:
        return list(args), []
    separator = list(args).index("--")
    return list(args[:separator]), list(args[separator + 1 :])


def load_manifest_payload(manifest_path: Path) -> dict:
    """Load one Dog Paw manifest from disk.

    Purpose:
        Centralizes manifest parsing for debug and install workflows that need a
        small amount of manifest metadata to compute command arguments.
    Parameters:
        manifest_path: Path to a readable `dogpawapp.json` file.
    Return value:
        Parsed manifest object.
    Requirements:
        `manifest_path` exists and contains valid JSON object text.
    Guarantees:
        Raises `ValueError` if the top-level JSON value is not an object.
    Invariants:
        Reads the manifest without modifying it.
    """

    payload = json.loads(manifest_path.read_text(encoding="utf-8"))
    if not isinstance(payload, dict):
        raise ValueError("Manifest must be a JSON object")
    return payload


def require_manifest_string_field(manifest_path: Path, payload: dict, field_name: str) -> str:
    """Read one required string field from a manifest payload.

    Purpose:
        Keeps manifest validation errors consistent for lightweight dispatcher
        workflows that only need a few manifest fields.
    Parameters:
        manifest_path: Manifest path used only for clear error messages.
        payload: Parsed manifest dictionary.
        field_name: Required top-level field name.
    Return value:
        Non-empty string field value.
    Requirements:
        `payload` came from `load_manifest_payload()`.
    Guarantees:
        Raises `ValueError` with the manifest path when the field is missing or
        not a non-empty string.
    Invariants:
        Does not mutate the payload.
    """

    value = payload.get(field_name)
    if not isinstance(value, str) or value == "":
        raise ValueError(f"Manifest {manifest_path} requires non-empty string field: {field_name}")
    return value


