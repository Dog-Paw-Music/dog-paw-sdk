def resolve_flutter_manifest_context(manifest_arg: str) -> FlutterManifestContext:
    """Resolve one Flutter manifest into reusable workflow context.

    Purpose:
        Keeps Flutter install/debug behavior aligned by validating manifests in
        one place and deriving the common relative paths used for remote sync.
    Parameters:
        manifest_arg: Local manifest path from CLI input.
    Return value:
        Fully resolved `FlutterManifestContext`.
    Requirements:
        `manifest_arg` names a manifest under `FLUTTER_WORKSPACE_ROOT`.
    Guarantees:
        Raises `ValueError` on invalid paths or missing required fields.
    Invariants:
        Relative paths are always computed against `FLUTTER_WORKSPACE_ROOT`.
    """

    manifest_path = resolve_local_cli_path(manifest_arg)
    if not manifest_path.is_file():
        raise ValueError(f"manifest not found: {manifest_path}")
    try:
        manifest_relative = manifest_path.relative_to(FLUTTER_WORKSPACE_ROOT)
    except ValueError as exc:
        raise ValueError(f"manifest must live under {FLUTTER_WORKSPACE_ROOT}") from exc

    manifest_payload = load_manifest_payload(manifest_path)
    app_name = require_manifest_string_field(manifest_path, manifest_payload, "name")
    flutter_project_rel = require_manifest_string_field(
        manifest_path,
        manifest_payload,
        "flutterApp",
    )
    app_dir = manifest_path.parent
    app_relative = app_dir.relative_to(FLUTTER_WORKSPACE_ROOT)
    flutter_project_dir = (app_dir / flutter_project_rel).resolve()
    if not flutter_project_dir.is_dir():
        raise ValueError(f"Flutter project not found: {flutter_project_dir}")
    return FlutterManifestContext(
        manifest_path=manifest_path,
        manifest_payload=manifest_payload,
        app_name=app_name,
        manifest_relative=manifest_relative,
        app_dir=app_dir,
        app_relative=app_relative,
        flutter_project_rel=flutter_project_rel,
        flutter_project_dir=flutter_project_dir,
    )


def resolve_flutter_prebuilt_bridge_path(target_arch: str) -> Path:
    """Resolve the packaged dogpaw bridge artifact for one target architecture.

    Purpose:
        Centralizes the packaged bridge-library layout used by Flutter install
        fingerprints so Pi workflows do not depend on legacy remote library
        copies.
    Parameters:
        target_arch: Dog Paw bridge package architecture name. Supported values
            are `x64` and `arm64`.
    Return value:
        Absolute path to the matching packaged `libdogpaw_bridge.so` artifact.
    Requirements:
        `target_arch` must be one of the supported package subdirectory names.
    Guarantees:
        Returns the expected package path even when the artifact is currently
        missing, so callers can treat that as part of fingerprint or validation
        behavior.
    Invariants:
        Does not inspect remote state or mutate local files.
    """

    if target_arch not in {"x64", "arm64"}:
        raise ValueError(f"unsupported Flutter bridge target architecture: {target_arch}")
    return (
        DOGPAW_PACKAGE_PREBUILT_ROOT
        / f"linux-{target_arch}"
        / "libdogpaw_bridge.so"
    )


def compute_flutter_host_source_fingerprint(
    context: FlutterManifestContext,
    build_mode: str,
    *,
    target_arch: str,
) -> str:
    """Compute the host-side Flutter source fingerprint for one app install.

    Purpose:
        Produces a host-comparable fingerprint for Pi install/update workflows
        that need to detect Flutter source, bridge, and build-mode changes
        without relying on Pi-local absolute paths.
    Parameters:
        context: Resolved Flutter manifest context for the app being installed.
        build_mode: Flutter Linux build mode that should affect reinstall
            decisions.
        target_arch: Packaged bridge artifact architecture name used by the
            target runtime, such as `arm64` for Pi installs.
    Return value:
        Stable fingerprint string using the shared install fingerprint format.
    Requirements:
        `context` describes a valid Flutter app manifest and `build_mode` is a
        non-empty Flutter Linux build mode string.
    Guarantees:
        Includes Flutter project source inputs plus the packaged bridge artifact
        path for the selected target architecture.
    Invariants:
        Reads source metadata only and never mutates workspace files.
    """

    if build_mode == "":
        raise ValueError("build_mode must be non-empty")
    install_support_app, install_fingerprint = load_install_support_modules()
    manifest = install_support_app.load_manifest(context.manifest_path)
    source_inputs = install_support_app.build_source_inputs(
        manifest,
        context.manifest_path,
        binary_path=None,
        bundle_path=None,
        extra_binary_paths=[],
    )
    source_inputs.append(resolve_flutter_prebuilt_bridge_path(target_arch))
    _, fingerprint = install_fingerprint.fingerprint_source_inputs_with_text(
        source_inputs,
        {"buildMode": build_mode},
    )
    return fingerprint


def globals_metadata_remote_path(remote_script_dir: PurePosixPath) -> PurePosixPath:
    """Return the remote metadata file path for deploy-globals fingerprints.

    Purpose:
        Keeps the globals metadata location centralized so install-updated and
        deploy-globals code agree on where the target stores the last deployed
        fingerprint.
    Parameters:
        remote_script_dir: Remote Dog Paw script root, typically
            `/home/dppi/scripts/dogpaw`.
    Return value:
        Remote metadata path under the generated-script directory.
    Requirements:
        `remote_script_dir` must be an absolute remote path.
    Guarantees:
        The returned path always lives below `<remote_script_dir>/generated/`.
    Invariants:
        Does not inspect or modify remote state.
    """

    return remote_script_dir / "generated" / "install_updated_globals_metadata.json"


def parse_string_array_field(payload: dict, field_name: str) -> tuple[str, ...]:
    """Read one optional top-level string array field from a manifest payload.

    Purpose:
        Keeps manifest parsing rules consistent for optional array fields used by
        install-updated planning such as `buildDependencies`.
    Parameters:
        payload: Parsed manifest JSON object.
        field_name: Top-level field name to read.
    Return value:
        Tuple of strings, or an empty tuple when the field is absent.
    Requirements:
        `payload` is a JSON object loaded from a Dog Paw manifest.
    Guarantees:
        Raises `ValueError` when the field exists but is not an array of
        strings.
    Invariants:
        Does not mutate the payload.
    """

    value = payload.get(field_name, [])
    if not isinstance(value, list) or not all(isinstance(item, str) for item in value):
        raise ValueError(f"{field_name} must be an array of strings")
    return tuple(value)


def parse_install_extra_binaries(payload: dict) -> tuple[str, ...]:
    """Read manifest `install.extraBinaries` for build-target expansion.

    Purpose:
        Lets install-updated reuse the existing helper-binary install contract
        when deciding which CMake targets must be built before staleness checks.
    Parameters:
        payload: Parsed manifest JSON object.
    Return value:
        Tuple of helper binary target names.
    Requirements:
        `payload` came from a Dog Paw manifest.
    Guarantees:
        Missing `install.extraBinaries` returns an empty tuple.
    Invariants:
        Only validates the metadata shape; it does not inspect build outputs.
    """

    install = payload.get("install", {})
    if install is None:
        return ()
    if not isinstance(install, dict):
        raise ValueError("install field must be an object")
    value = install.get("extraBinaries", [])
    if not isinstance(value, list) or not all(isinstance(item, str) for item in value):
        raise ValueError("install.extraBinaries must be an array of strings")
    return tuple(value)


def host_manifest_from_path(manifest_path: Path) -> HostAppManifest:
    """Build one install-updated manifest summary from a source manifest path.

    Purpose:
        Converts a full Dog Paw manifest into the narrow host-side metadata used
        by install-updated planning and target-union expansion.
    Parameters:
        manifest_path: Source-tree `dogpawapp.json` path.
    Return value:
        Parsed `HostAppManifest`.
    Requirements:
        `manifest_path` exists and contains valid JSON.
    Guarantees:
        Resolves the path to an absolute path and validates the fields used by
        install-updated.
    Invariants:
        Does not copy, stage, or mutate manifest files.
    """

    payload = load_manifest_payload(manifest_path.resolve())
    name = require_manifest_string_field(manifest_path, payload, "name")
    flutter_app = payload.get("flutterApp")
    is_flutter = isinstance(flutter_app, str) and flutter_app != ""
    executable = None
    if not is_flutter:
        executable = require_manifest_string_field(manifest_path, payload, "executable")
    return HostAppManifest(
        name=name,
        manifest_path=manifest_path.resolve(),
        is_flutter=is_flutter,
        executable=executable,
        extra_binaries=parse_install_extra_binaries(payload),
        build_dependencies=parse_string_array_field(payload, "buildDependencies"),
        install_dependencies=parse_string_array_field(payload, "installDependencies"),
    )


def expand_manifests_with_install_dependencies(
    seed_manifests: Sequence[HostAppManifest],
    host_manifest_index: dict[str, HostAppManifest],
) -> tuple[HostAppManifest, ...]:
    """Expand one manifest scope with transitive `installDependencies`.

    Purpose:
        Ensures install-updated and headless install workflows pull in registry
        apps that scoped parents require at runtime, including transitive
        dependencies declared by manifest app names.
    Parameters:
        seed_manifests: Manifests already in scope before dependency expansion.
        host_manifest_index: Mapping from manifest `name` to host manifest
            metadata used to resolve dependency names.
    Return value:
        Ordered tuple of unique manifests with dependencies before dependents.
    Requirements:
        Every `installDependencies` entry must resolve to a manifest in
        `host_manifest_index` or among `seed_manifests`.
    Guarantees:
        Circular dependency graphs terminate without infinite recursion.
    Invariants:
        Does not mutate manifests or the host manifest index.
    """

    index = dict(host_manifest_index)
    for manifest in seed_manifests:
        index.setdefault(manifest.name, manifest)

    ordered: list[HostAppManifest] = []
    seen_names: set[str] = set()
    visiting: set[str] = set()

    def visit(manifest: HostAppManifest) -> None:
        if manifest.name in seen_names:
            return
        if manifest.name in visiting:
            return
        visiting.add(manifest.name)
        for dependency_name in manifest.install_dependencies:
            dependency = index.get(dependency_name)
            if dependency is None:
                raise ValueError(
                    f"install dependency has no host manifest: {dependency_name}"
                )
            visit(dependency)
        visiting.discard(manifest.name)
        seen_names.add(manifest.name)
        ordered.append(manifest)

    for manifest in seed_manifests:
        visit(manifest)
    return tuple(ordered)


def collect_install_updated_seed_manifests(
    *,
    host_manifest_index: dict[str, HostAppManifest],
    remote_apps: Sequence[dict[str, object]],
    include_startup_plan: bool,
    startup_plan_app_names: Sequence[str],
) -> tuple[HostAppManifest, ...]:
    """Collect the initial install-updated scope before dependency expansion.

    Purpose:
        Derives the same seed manifest set used by planning and pre-build steps
        so startup-plan and installed-app scope stay aligned.
    Parameters:
        host_manifest_index: Mapping from manifest `name` to host manifest
            metadata.
        remote_apps: Installed-app inventory records from the target.
        include_startup_plan: Whether startup-plan app names should be added to
            scope even when not yet installed.
        startup_plan_app_names: Ordered startup-plan app names to add when
            `include_startup_plan` is true.
    Return value:
        Ordered tuple of unique seed manifests without dependency expansion.
    Requirements:
        Startup-plan names must exist in `host_manifest_index` when included.
    Guarantees:
        Duplicate app names keep their first occurrence order.
    Invariants:
        Does not inspect build outputs or mutate remote state.
    """

    seed_manifests: dict[str, HostAppManifest] = {}
    for remote_app in remote_apps:
        app_name_value = remote_app.get("appName")
        app_name = app_name_value if isinstance(app_name_value, str) and app_name_value != "" else None
        metadata = remote_app.get("metadata") if isinstance(remote_app.get("metadata"), dict) else None
        if app_name is None and metadata is not None:
            metadata_app_name = metadata.get("appName")
            if isinstance(metadata_app_name, str) and metadata_app_name != "":
                app_name = metadata_app_name
        if app_name is None:
            continue
        manifest = host_manifest_index.get(app_name)
        if manifest is not None:
            seed_manifests[app_name] = manifest
    if include_startup_plan:
        for app_name in startup_plan_app_names:
            manifest = host_manifest_index.get(app_name)
            if manifest is None:
                raise ValueError(f"startup plan app has no host manifest: {app_name}")
            seed_manifests[app_name] = manifest
    return tuple(seed_manifests.values())


def extract_manifest_option_values(args: Sequence[str]) -> list[str]:
    """Read repeated `--manifest` values from one delegated argument list.

    Purpose:
        Lets headless install dispatch expand explicit manifest selections
        before delegating to the deploy helper.
    Parameters:
        args: Delegated command arguments after path rewriting.
    Return value:
        Manifest paths in the order they appeared on the command line.
    Requirements:
        `args` preserves the user's original argument order.
    Guarantees:
        Stops scanning at a literal `--` separator.
    Invariants:
        Does not resolve or validate manifest paths.
    """

    values: list[str] = []
    skip_next = False
    for index, token in enumerate(args):
        if skip_next:
            skip_next = False
            continue
        if token == "--":
            break
        if token == "--manifest":
            if index + 1 < len(args):
                values.append(args[index + 1])
                skip_next = True
            continue
        if token.startswith("--manifest="):
            values.append(token.split("=", 1)[1])
    return values


def replace_manifest_option_values(
    args: Sequence[str],
    manifest_paths: Sequence[str],
) -> list[str]:
    """Replace all `--manifest` values in one delegated argument list.

    Purpose:
        Rewrites headless install commands after expanding install dependencies
        while preserving unrelated flags such as `--target` and `--build-dir`.
    Parameters:
        args: Delegated command arguments after path rewriting.
        manifest_paths: Replacement manifest paths in desired install order.
    Return value:
        New argument list with prior `--manifest` entries removed and replaced.
    Requirements:
        `manifest_paths` must contain at least one path when used for deploy.
    Guarantees:
        Stops scanning at a literal `--` separator and leaves trailing passthrough
        arguments untouched.
    Invariants:
        Does not mutate the original `args` sequence.
    """

    filtered: list[str] = []
    skip_next = False
    passthrough: list[str] = []
    saw_separator = False
    for index, token in enumerate(args):
        if saw_separator:
            passthrough.append(token)
            continue
        if skip_next:
            skip_next = False
            continue
        if token == "--":
            saw_separator = True
            continue
        if token == "--manifest":
            if index + 1 < len(args):
                skip_next = True
            continue
        if token.startswith("--manifest="):
            continue
        filtered.append(token)
    rewritten = list(filtered)
    for manifest_path in manifest_paths:
        rewritten.extend(["--manifest", manifest_path])
    if saw_separator:
        rewritten.append("--")
        rewritten.extend(passthrough)
    return rewritten


def resolve_option_from_args(
    args: Sequence[str],
    option_names: set[str],
    default: str | None = None,
) -> str | None:
    """Resolve one option value from a delegated argument list.

    Purpose:
        Reads common workflow flags from pass-through command arguments without
        requiring a dedicated parser for every delegated shell helper.
    Parameters:
        args: Delegated command arguments.
        option_names: Long or short option spellings to match.
        default: Value returned when no matching option is present.
    Return value:
        The option value, or `default` when the option is absent.
    Requirements:
        `args` preserves the user's original argument order.
    Guarantees:
        Stops scanning at a literal `--` separator.
    Invariants:
        Does not mutate the input sequence.
    """

    for index, token in enumerate(args):
        if token == "--":
            break
        if token in option_names and index + 1 < len(args):
            return args[index + 1]
        for option_name in option_names:
            if token.startswith(f"{option_name}="):
                return token.split("=", 1)[1]
    return default


def build_host_manifest_index(manifest_paths: Sequence[Path]) -> dict[str, HostAppManifest]:
    """Build a manifest-name index for install-updated planning.

    Purpose:
        Lets install-updated resolve installed or startup-plan app names back to
        source-tree manifests without trusting remote source paths.
    Parameters:
        manifest_paths: Candidate source-tree manifest paths.
    Return value:
        Mapping from manifest `name` to parsed host manifest summary.
    Requirements:
        Candidate manifests must be valid Dog Paw manifests.
    Guarantees:
        Earlier manifest paths win when duplicate names appear.
    Invariants:
        Only reads local manifest files.
    """

    index: dict[str, HostAppManifest] = {}
    for manifest_path in manifest_paths:
        manifest = host_manifest_from_path(manifest_path)
        if manifest.name not in index:
            index[manifest.name] = manifest
    return index


def build_host_manifest_index_from_workspace() -> dict[str, HostAppManifest]:
    """Scan the workspace for host manifests used by install-updated.

    Purpose:
        Centralizes the supported source-tree search roots for Dog Paw app
        manifests so install-updated and future tooling share one lookup rule.
    Parameters:
        None.
    Return value:
        Mapping from manifest `name` to parsed host manifest summary.
    Requirements:
        The repository workspace layout matches the current Dog Paw source tree.
    Guarantees:
        Scans the source-tree headless-app and Flutter-app manifest roots defined
        by the repo-only workspace helper.
    Invariants:
        Does not inspect installed app registries or remote hosts.
    """

    repo_layout = load_repo_only_workspace_helper()
    manifest_paths = repo_layout.repo_app_manifest_paths(WORKSPACE_ROOT)
    return build_host_manifest_index(manifest_paths)


def startup_plan_app_names(startup_plan_path: Path) -> tuple[str, ...]:
    """Read `launch_app` names from one startup plan JSON document.

    Purpose:
        Supports the `--include-startup-plan` option by deriving desired app
        scope from the same startup plan shape Epiphany consumes.
    Parameters:
        startup_plan_path: Local startup plan JSON file.
    Return value:
        Ordered tuple of unique app names from `launch_app` actions.
    Requirements:
        `startup_plan_path` exists and contains a JSON object with an `actions`
        list.
    Guarantees:
        Duplicate app names keep their first occurrence order.
    Invariants:
        Reads the startup plan only; does not modify it.
    """

    payload = json.loads(startup_plan_path.read_text(encoding="utf-8"))
    actions = payload.get("actions", [])
    if not isinstance(actions, list):
        raise ValueError(f"startup plan actions must be a list: {startup_plan_path}")
    names: list[str] = []
    seen: set[str] = set()
    for action in actions:
        if not isinstance(action, dict) or action.get("type") != "launch_app":
            continue
        app_name = action.get("app")
        if isinstance(app_name, str) and app_name not in seen:
            names.append(app_name)
            seen.add(app_name)
    return tuple(names)


def compute_deploy_globals_fingerprint(hardware_profile: str) -> str:
    """Compute the host-side fingerprint for shared deploy globals.

    Purpose:
        Lets install-updated decide whether runtime-global deploy artifacts such
        as startup scripts, generated hardware-profile output, images, and
        `dogpawDataItems` need to be resynced to the target.
    Parameters:
        hardware_profile: Hardware profile name used to generate the runtime
            `hardware_profile.sh`.
    Return value:
        Stable fingerprint string for the current deploy-globals inputs.
    Requirements:
        `hardware_profile` is a non-empty profile name accepted by
        `generate_hardware_profile.sh`.
    Guarantees:
        Includes the generated hardware-profile shell file plus the supported
        runtime-global resource directories and launch scripts.
    Invariants:
        Leaves repository files unchanged; temporary files are cleaned up before
        return.
    """

    if hardware_profile == "":
        raise ValueError("hardware_profile must be non-empty")
    _, install_fingerprint = load_install_support_modules()
    repo_layout = load_repo_only_workspace_helper()
    generator = PI_RESOURCE_SCRIPTS_ROOT / "generate_hardware_profile.sh"
    with tempfile.TemporaryDirectory() as temp_dir:
        generated_path = Path(temp_dir) / "hardware_profile.sh"
        completed = subprocess.run(
            [str(generator), "-o", str(generated_path), hardware_profile],
            cwd=WORKSPACE_ROOT,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=False,
        )
        if completed.returncode != 0:
            raise RuntimeError(completed.stderr.strip() or "failed to generate hardware profile")
        source_inputs = repo_layout.deploy_globals_source_inputs(
            WORKSPACE_ROOT,
            generated_path,
        )
        _, fingerprint = install_fingerprint.fingerprint_source_inputs(source_inputs)
    return fingerprint


def resolve_headless_build_inputs(
    manifest: HostAppManifest,
    build_dir: Path,
) -> tuple[Path, tuple[Path, ...]]:
    """Resolve the current build-output paths for one headless app manifest.

    Purpose:
        Centralizes how install-updated maps a host manifest to the current
        workspace build outputs so headless stale checks follow the selected
        `--build-dir` instead of any historical absolute paths stored on the Pi.
    Parameters:
        manifest: Host manifest summary for the headless app being checked.
        build_dir: Local CMake build directory whose `bin/` contents should
            define the current app install fingerprint.
    Return value:
        Tuple of `(primary_binary_path, extra_binary_paths)` resolved from the
        manifest's executable and `install.extraBinaries`.
    Requirements:
        `manifest` must describe a headless app with a non-empty executable
        target name.
    Guarantees:
        Returns absolute paths under `<build_dir>/bin` even when some current
        outputs are missing, so missing outputs still affect the fingerprint.
    Invariants:
        Does not inspect remote state or mutate local files.
    """

    if manifest.is_flutter:
        raise ValueError("resolve_headless_build_inputs requires a headless manifest")
    if manifest.executable is None:
        raise ValueError("headless manifest requires an executable")
    binary_path = (build_dir / "bin" / manifest.executable).resolve()
    extra_binary_paths = tuple(
        (build_dir / "bin" / binary_name).resolve()
        for binary_name in manifest.extra_binaries
    )
    return binary_path, extra_binary_paths


def compute_headless_host_source_fingerprint(
    manifest: HostAppManifest,
    build_dir: Path,
) -> str:
    """Compute the current workspace fingerprint for one headless app install.

    Purpose:
        Mirrors the Flutter install-updated model for headless apps by
        fingerprinting the current workspace manifest, selected build outputs,
        and manifest-declared assets instead of trusting historical remote
        `sourceInputs`.
    Parameters:
        manifest: Host manifest summary for the headless app being checked.
        build_dir: Local CMake build directory whose outputs define the current
            install candidate.
    Return value:
        Stable shared-install fingerprint string for the current workspace view
        of the headless app.
    Requirements:
        `manifest` must describe a headless app and `build_dir` must identify
        the build tree chosen for this install-updated run.
    Guarantees:
        Includes the same source-input recipe used by headless installs:
        manifest, main binary, extra binaries, and manifest-declared assets.
    Invariants:
        Reads local source and build paths only; it does not stage, build, or
        mutate files.
    """

    if manifest.is_flutter:
        raise ValueError("compute_headless_host_source_fingerprint requires a headless manifest")
    install_support_app, install_fingerprint = load_install_support_modules()
    manifest_payload = load_manifest_payload(manifest.manifest_path)
    binary_path, extra_binary_paths = resolve_headless_build_inputs(manifest, build_dir)
    source_inputs = install_support_app.build_source_inputs(
        manifest_payload,
        manifest.manifest_path,
        binary_path=binary_path,
        bundle_path=None,
        extra_binary_paths=extra_binary_paths,
    )
    _, fingerprint = install_fingerprint.fingerprint_source_inputs(source_inputs)
    return fingerprint


def headless_app_is_stale(
    manifest: HostAppManifest,
    metadata: dict[str, object] | None,
    *,
    build_dir: Path,
) -> bool:
    """Return whether one installed headless app should be redeployed.

    Purpose:
        Reuses the existing install-metadata fingerprint contract for headless
        apps while resolving the current fingerprint from the selected
        workspace manifest and build directory, not from historical absolute
        source paths stored on the target.
    Parameters:
        manifest: Host manifest summary for the app being checked.
        metadata: Parsed remote `install_metadata.json`, or `None` when missing.
        build_dir: Local CMake build directory whose `bin/` outputs should
            define the current install candidate.
    Return value:
        `True` when the app should be treated as stale.
    Requirements:
        `manifest` must describe a headless app. When present, `metadata`
        follows the existing install metadata schema.
    Guarantees:
        Missing or invalid metadata returns `True` instead of raising.
    Invariants:
        Reads current workspace source/build inputs only and does not modify
        them.
    """

    if manifest.is_flutter:
        raise ValueError("headless_app_is_stale requires a headless manifest")
    if not isinstance(metadata, dict):
        return True
    source_fingerprint = metadata.get("sourceFingerprint")
    if not isinstance(source_fingerprint, str) or source_fingerprint == "":
        return True
    try:
        current_fingerprint = compute_headless_host_source_fingerprint(
            manifest,
            build_dir,
        )
    except Exception:
        return True
    return current_fingerprint != source_fingerprint


def flutter_app_is_stale(
    manifest: HostAppManifest,
    metadata: dict[str, object] | None,
    *,
    build_mode: str,
    current_pi_flutter_sdk_version: str | None,
) -> bool:
    """Return whether one installed Flutter app should be reinstalled.

    Purpose:
        Compares install-updated's host-side Flutter fingerprint recipe against
        the metadata written during the last Pi install.
    Parameters:
        manifest: Host manifest summary for the app.
        metadata: Parsed remote `install_metadata.json`, or `None` when missing.
        build_mode: Requested Flutter build mode for this run.
        current_pi_flutter_sdk_version: Current Flutter SDK version on the Pi.
    Return value:
        `True` when the app should be treated as stale.
    Requirements:
        `manifest` must describe a Flutter app.
    Guarantees:
        Missing host-side metadata fields return `True` instead of raising.
    Invariants:
        Reads local source inputs and packaged bridge artifacts only.
    """

    if not manifest.is_flutter:
        raise ValueError("flutter_app_is_stale requires a Flutter manifest")
    if not isinstance(metadata, dict):
        return True
    stored_fingerprint = metadata.get("hostSourceFingerprint")
    stored_build_mode = metadata.get("hostBuildMode")
    stored_sdk_version = metadata.get("flutterSdkVersion")
    if (
        not isinstance(stored_fingerprint, str)
        or stored_fingerprint == ""
        or not isinstance(stored_build_mode, str)
        or stored_build_mode == ""
        or not isinstance(stored_sdk_version, str)
        or stored_sdk_version == ""
        or current_pi_flutter_sdk_version is None
    ):
        return True
    current_fingerprint = compute_flutter_host_source_fingerprint(
        resolve_flutter_manifest_context(str(manifest.manifest_path)),
        build_mode,
        target_arch="arm64",
    )
    return (
        current_fingerprint != stored_fingerprint
        or stored_build_mode != build_mode
        or stored_sdk_version != current_pi_flutter_sdk_version
    )


def build_targets_for_manifests(manifests: Sequence[HostAppManifest]) -> tuple[str, ...]:
    """Return the ordered CMake target union for install-updated scope.

    Purpose:
        Encodes the agreed target-union rules so install-updated can rebuild all
        in-scope app outputs before staleness checks and deployment.
    Parameters:
        manifests: Host manifests in the final candidate scope.
    Return value:
        Ordered tuple of unique CMake target names.
    Requirements:
        Manifest metadata already reflects the source of truth for executable,
        extra-binary, and build-dependency targets.
    Guarantees:
        Includes `dogpaw_bridge` when any Flutter app is in scope and always
        includes `Epiphany`.
    Invariants:
        Does not inspect build directories or remote targets.
    """

    targets: list[str] = []
    seen: set[str] = set()

    def append_target(name: str) -> None:
        if name != "" and name not in seen:
            targets.append(name)
            seen.add(name)

    has_flutter = any(manifest.is_flutter for manifest in manifests)
    for manifest in manifests:
        if manifest.executable is not None:
            append_target(manifest.executable)
        for extra_binary in manifest.extra_binaries:
            append_target(extra_binary)
        for dependency in manifest.build_dependencies:
            append_target(dependency)
    if has_flutter:
        append_target("dogpaw_bridge")
    append_target("Epiphany")
    return tuple(targets)


def plan_install_updated(
    *,
    host_manifest_index: dict[str, HostAppManifest],
    remote_apps: Sequence[dict[str, object]],
    include_startup_plan: bool,
    startup_plan_app_names: Sequence[str],
    current_pi_flutter_sdk_version: str | None,
    build_mode: str,
    build_dir: Path,
    globals_stale: bool = False,
) -> InstallUpdatedPlan:
    """Plan install-updated actions from host manifests and remote app state.

    Purpose:
        Converts remote installed-app inventory plus local manifest discovery into
        explicit stale-app, orphan-prune, warning, and build-target decisions.
    Parameters:
        host_manifest_index: Mapping from app name to source-tree manifest
            metadata.
        remote_apps: Installed-app inventory records from the target.
        include_startup_plan: Whether startup-plan app names should be added to
            scope even when not installed.
        startup_plan_app_names: Ordered startup-plan app names to add when
            `include_startup_plan` is true.
        current_pi_flutter_sdk_version: Current Flutter SDK version on the Pi,
            used for Flutter staleness checks.
        build_mode: Requested Flutter build mode for this run.
        build_dir: Local CMake build directory whose `bin/` outputs should be
            used for current headless staleness checks.
        globals_stale: Whether shared deploy globals need resync.
    Return value:
        Immutable `InstallUpdatedPlan`.
    Requirements:
        Headless build outputs must already be current if the caller expects
        stale-headless decisions to reflect the latest binaries.
    Guarantees:
        Startup-plan names missing from the host manifest index raise
        `ValueError`. Unknown installed apps warn and skip. Managed orphan
        directories are pruned only when they still have install metadata.
    Invariants:
        Does not mutate local manifests or remote app records.
    """

    warnings: list[str] = []
    stale_headless_manifests: list[Path] = []
    stale_flutter_manifests: list[Path] = []
    orphaned_app_dirs: list[PurePosixPath] = []
    installed_names: set[str] = set()
    installed_metadata_by_name: dict[str, dict[str, object]] = {}

    for remote_app in remote_apps:
        install_dir_text = remote_app.get("installDir")
        install_dir = PurePosixPath(str(install_dir_text)) if install_dir_text is not None else None
        app_name_value = remote_app.get("appName")
        app_name = app_name_value if isinstance(app_name_value, str) and app_name_value != "" else None
        metadata = remote_app.get("metadata") if isinstance(remote_app.get("metadata"), dict) else None
        if app_name is None and metadata is not None:
            metadata_app_name = metadata.get("appName")
            if isinstance(metadata_app_name, str) and metadata_app_name != "":
                app_name = metadata_app_name
        if app_name is None:
            warning_path = str(install_dir) if install_dir is not None else "<unknown>"
            warnings.append(
                f"Warning: skipping installed app with no recoverable name at {warning_path}"
            )
            continue
        installed_names.add(app_name)
        if metadata is not None:
            installed_metadata_by_name[app_name] = metadata
        manifest = host_manifest_index.get(app_name)
        if manifest is None:
            if metadata is not None and install_dir is not None:
                orphaned_app_dirs.append(install_dir)
            else:
                warnings.append(
                    f"Warning: skipping unknown installed app '{app_name}' because no host manifest exists"
                )
            continue

    seed_manifests = collect_install_updated_seed_manifests(
        host_manifest_index=host_manifest_index,
        remote_apps=remote_apps,
        include_startup_plan=include_startup_plan,
        startup_plan_app_names=startup_plan_app_names,
    )
    scoped_manifests = expand_manifests_with_install_dependencies(
        seed_manifests,
        host_manifest_index,
    )

    for manifest in scoped_manifests:
        app_name = manifest.name
        metadata = installed_metadata_by_name.get(app_name)
        if app_name not in installed_names:
            if manifest.is_flutter:
                stale_flutter_manifests.append(manifest.manifest_path)
            else:
                stale_headless_manifests.append(manifest.manifest_path)
            continue
        if manifest.is_flutter:
            if flutter_app_is_stale(
                manifest,
                metadata,
                build_mode=build_mode,
                current_pi_flutter_sdk_version=current_pi_flutter_sdk_version,
            ):
                stale_flutter_manifests.append(manifest.manifest_path)
        elif headless_app_is_stale(
            manifest,
            metadata,
            build_dir=build_dir,
        ):
            stale_headless_manifests.append(manifest.manifest_path)

    build_targets = build_targets_for_manifests(scoped_manifests)
    return InstallUpdatedPlan(
        stale_headless_manifests=tuple(dict.fromkeys(stale_headless_manifests)),
        stale_flutter_manifests=tuple(dict.fromkeys(stale_flutter_manifests)),
        orphaned_app_dirs=tuple(orphaned_app_dirs),
        warnings=tuple(warnings),
        build_targets=build_targets,
        globals_stale=globals_stale,
    )


def build_flutter_remote_paths(
    context: FlutterManifestContext,
    remote_source_root: PurePosixPath,
) -> dict[str, PurePosixPath]:
    """Build remote source-tree paths for one Flutter app workflow.

    Purpose:
        Ensures install and debug flows agree on where synced packages, tools,
        manifests, and Flutter project files live on the remote Pi.
    Parameters:
        context: Resolved local Flutter manifest metadata.
        remote_source_root: Remote root that should contain the temporary
            Flutter workspace source tree.
    Return value:
        Mapping of named remote paths used by higher-level workflow builders.
    Requirements:
        `remote_source_root` must be an absolute Pi path.
    Guarantees:
        Returns only pure path calculations; no network or filesystem I/O occurs.
    Invariants:
        Returned paths remain under `remote_source_root`.
    """

    remote_ui_root = remote_source_root
    remote_app_dir = remote_ui_root / PurePosixPath(context.app_relative.as_posix())
    return {
        "remote_ui_root": remote_ui_root,
        "remote_ui_tools_dir": remote_ui_root / "tools",
        "remote_packages_dir": remote_ui_root / "packages",
        "remote_app_dir": remote_app_dir,
        "remote_manifest_path": remote_ui_root
        / PurePosixPath(context.manifest_relative.as_posix()),
        "remote_flutter_project_dir": remote_app_dir / context.flutter_project_rel,
    }


def build_flutter_source_sync_commands(
    context: FlutterManifestContext,
    target: str,
    remote_source_root: PurePosixPath,
    remote_app_root: PurePosixPath,
) -> list[list[str]]:
    """Build the common remote source-sync commands for Flutter workflows.

    Purpose:
        Shares the temporary-source sync contract between install and debug so
        both flows stage the same files on the Pi.
    Parameters:
        context: Resolved Flutter manifest context.
        target: Remote SSH target.
        remote_source_root: Remote temporary Flutter workspace source root.
        remote_app_root: Remote installed Dog Paw app root.
    Return value:
        Ordered command list for directory creation and rsync operations.
    Requirements:
        `target` must be a non-empty SSH host string.
    Guarantees:
        Sync set includes shared `packages/`, the selected app tree, and the
        install helper scripts needed by the remote build.
    Invariants:
        The returned list does not depend on current network state.
    """

    remote_paths = build_flutter_remote_paths(context, remote_source_root)
    ssh_transport = shell_join(SSH_BASE_ARGS)
    tools_dir = FLUTTER_WORKSPACE_ROOT / "tools"

    remote_prepare_command = shell_join(
        [
            "mkdir",
            "-p",
            str(remote_paths["remote_ui_tools_dir"]),
            str(remote_paths["remote_packages_dir"]),
            str(remote_paths["remote_app_dir"]),
            str(remote_app_root),
        ]
    )
    return [
        [*SSH_BASE_ARGS, target, remote_prepare_command],
        [
            *RSYNC_BASE_ARGS,
            "-e",
            ssh_transport,
            f"{FLUTTER_WORKSPACE_ROOT / 'packages'}/",
            f"{target}:{remote_paths['remote_packages_dir']}/",
        ],
        [
            *RSYNC_BASE_ARGS,
            "-e",
            ssh_transport,
            f"{context.app_dir}/",
            f"{target}:{remote_paths['remote_app_dir']}/",
        ],
        [
            "rsync",
            "-az",
            "-e",
            ssh_transport,
            str(tools_dir / "build_and_install_flutter_app.sh"),
            str(FLUTTER_INSTALL_TOOL),
            str(INSTALL_SUPPORT_TOOLS_ROOT / "install_fingerprint.py"),
            f"{target}:{remote_paths['remote_ui_tools_dir']}/",
        ],
    ]


def build_remote_flutter_install_command(
    context: FlutterManifestContext,
    remote_source_root: PurePosixPath,
    remote_app_root: PurePosixPath,
    remote_flutter_root: PurePosixPath,
    build_mode: str,
    host_source_fingerprint: str,
    keep_cache_on_install: bool,
) -> str:
    """Build the remote build-and-install shell command for one Flutter app.

    Purpose:
        Reuses the existing remote installer so Flutter install and debug flows
        both refresh the installed app root through the same bundle layout.
    Parameters:
        context: Resolved Flutter manifest context.
        remote_source_root: Remote temporary Flutter workspace source root.
        remote_app_root: Remote installed Dog Paw app root.
        remote_flutter_root: Remote Flutter SDK root.
        build_mode: Flutter Linux build mode to pass through.
        host_source_fingerprint: Host-computed fingerprint used for future
            install-updated comparisons.
        keep_cache_on_install: Whether to preserve the app cache instead of
            clearing it during remote install.
    Return value:
        Shell command string for one remote `bash -lc` invocation.
    Requirements:
        `build_mode` must be valid for `flutter build linux`.
    Guarantees:
        Returned command adds the remote Flutter SDK to PATH, sets
        `DOGPAW_APP_DIR` for the installer, and forwards host metadata needed by
        future install-updated comparisons.
    Invariants:
        The command references only the supplied remote roots.
    """

    remote_paths = build_flutter_remote_paths(context, remote_source_root)
    remote_installer = remote_paths["remote_ui_tools_dir"] / "build_and_install_flutter_app.sh"
    remote_path = f"{remote_flutter_root}/bin:{REMOTE_BASE_PATH}"
    command = (
        f"chmod +x {shlex.quote(str(remote_installer))} && "
        f"env PATH={shlex.quote(remote_path)} "
        f"DOGPAW_APP_DIR={shlex.quote(str(remote_app_root))} "
        f"{shlex.quote(str(remote_installer))} "
        f"--manifest {shlex.quote(str(remote_paths['remote_manifest_path']))} "
        f"--app-root {shlex.quote(str(remote_app_root))} "
        f"--build-mode {shlex.quote(build_mode)} "
        f"--host-source-fingerprint {shlex.quote(host_source_fingerprint)} "
        f"--host-build-mode {shlex.quote(build_mode)}"
    )
    if keep_cache_on_install:
        command += " --keep-cache-on-install"
    return command


