def append_env_if_missing(assignments: Sequence[str], assignment: str) -> list[str]:
    """Append one remote env assignment only when its key is absent.

    Purpose:
        Lets wrapper workflows supply default runtime environment values without
        overwriting explicit user-provided assignments.
    Parameters:
        assignments: Existing NAME=VALUE assignments.
        assignment: Default NAME=VALUE assignment to append when missing.
    Return value:
        New assignment list preserving original order.
    Requirements:
        `assignment` must contain `=`.
    Guarantees:
        The returned list contains exactly one assignment for the given key.
    Invariants:
        Existing assignment strings are preserved byte-for-byte.
    """

    key = assignment.split("=", 1)[0]
    if any(existing.split("=", 1)[0] == key for existing in assignments):
        return list(assignments)
    return [*assignments, assignment]


def build_remote_flutter_debug_command(
    context: FlutterManifestContext,
    remote_source_root: PurePosixPath,
    remote_app_root: PurePosixPath,
    remote_flutter_root: PurePosixPath,
    bridge_lib: str,
    instance_name: str,
    remote_port: str,
    device_id: str,
    start_paused: bool,
) -> str:
    """Build the remote wrapper command for one Flutter debug session.

    Purpose:
        Launches `flutter run` inside the synced remote source tree while
        exporting installed-path runtime variables and recovering the active
        Sway/Wayland session from the Pi so the Linux desktop app can render.
    Parameters:
        context: Resolved Flutter manifest context.
        remote_source_root: Remote temporary Flutter workspace source root.
        remote_app_root: Remote installed app root for `DOGPAW_APP_DIR`.
        remote_flutter_root: Remote Flutter SDK root whose `bin/` must be in PATH.
        bridge_lib: Remote bridge library path to export when it exists.
        instance_name: `EPIPHANY_INSTANCE` value for the debugged app.
        remote_port: Remote Dart VM service port used by `flutter run` on the Pi.
        device_id: Flutter device id to pass to `flutter run`.
        start_paused: Whether `flutter run` should wait for debugger attach.
    Return value:
        One `bash -lc` command string suitable for execution over SSH.
    Requirements:
        `remote_port` and `instance_name` are non-empty strings.
    Guarantees:
        The wrapper prints `Flutter VM service ready: ...` once the VM service
        URL file is populated and kills the child `flutter run` process on shell
        exit or disconnect.
    Invariants:
        Runtime asset lookup remains rooted at `remote_app_root`, not the
        temporary source tree.
    """

    remote_paths = build_flutter_remote_paths(context, remote_source_root)
    remote_project_dir = remote_paths["remote_flutter_project_dir"]
    remote_vmservice_file = remote_project_dir / ".dogpaw-vmservice-uri"
    remote_path = f"{remote_flutter_root}/bin:{REMOTE_BASE_PATH}"
    start_paused_flag = "--start-paused" if start_paused else ""
    return f"""set -euo pipefail
resolve_wayland_env() {{
python3 - <<'PY'
import os
import subprocess
import sys

KEYS = ("WAYLAND_DISPLAY", "XDG_RUNTIME_DIR", "SWAYSOCK", "DBUS_SESSION_BUS_ADDRESS")


def emit_exports(env: dict[str, str]) -> None:
    for key in KEYS:
        value = env.get(key)
        if value:
            print(f"export {{key}}={{value!r}}")


def parse_key_value_lines(text: str) -> dict[str, str]:
    env: dict[str, str] = {{}}
    for line in text.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        env[key] = value
    return env


def enrich_from_runtime_dir(env: dict[str, str]) -> dict[str, str]:
    runtime_dir = env.get("XDG_RUNTIME_DIR")
    if not runtime_dir or not os.path.isdir(runtime_dir):
        return env
    if not env.get("WAYLAND_DISPLAY"):
        wayland_candidates = sorted(
            name
            for name in os.listdir(runtime_dir)
            if name.startswith("wayland-") and not name.endswith(".lock")
        )
        if wayland_candidates:
            env["WAYLAND_DISPLAY"] = wayland_candidates[0]
    if not env.get("SWAYSOCK"):
        sway_candidates = sorted(
            name
            for name in os.listdir(runtime_dir)
            if name.startswith("sway-ipc.") and name.endswith(".sock")
        )
        if sway_candidates:
            env["SWAYSOCK"] = os.path.join(runtime_dir, sway_candidates[0])
    if not env.get("DBUS_SESSION_BUS_ADDRESS"):
        bus_path = os.path.join(runtime_dir, "bus")
        if os.path.exists(bus_path):
            env["DBUS_SESSION_BUS_ADDRESS"] = f"unix:path={{bus_path}}"
    return env


def parse_proc_environ(pid: str) -> dict[str, str]:
    with open(f"/proc/{{pid}}/environ", "rb") as environ_file:
        raw_entries = environ_file.read().split(b"\\0")
    env: dict[str, str] = {{}}
    for entry in raw_entries:
        if not entry or b"=" not in entry:
            continue
        key, value = entry.split(b"=", 1)
        env[key.decode("utf-8", "ignore")] = value.decode("utf-8", "ignore")
    return env

show_environment = subprocess.run(
    ["systemctl", "--user", "show-environment"],
    text=True,
    capture_output=True,
    check=False,
)
if show_environment.returncode == 0:
    systemd_env = enrich_from_runtime_dir(parse_key_value_lines(show_environment.stdout))
    if systemd_env.get("WAYLAND_DISPLAY") and systemd_env.get("XDG_RUNTIME_DIR"):
        emit_exports(systemd_env)
        raise SystemExit(0)

pids: list[str] = []
for pid in sorted(pid for pid in os.listdir("/proc") if pid.isdigit()):
    try:
        with open(f"/proc/{{pid}}/comm", "r", encoding="utf-8") as comm_file:
            if comm_file.read().strip() != "sway":
                continue
        pids.append(pid)
    except OSError:
        continue

if not pids:
    raise SystemExit("Could not find a running sway session on the remote Pi")

env = enrich_from_runtime_dir(parse_proc_environ(pids[0]))
required_keys = ["WAYLAND_DISPLAY", "XDG_RUNTIME_DIR"]
missing = [key for key in required_keys if not env.get(key)]
if missing:
    raise SystemExit(
        "Sway session is missing required environment values: " + ", ".join(missing)
    )

emit_exports(env)
PY
}}

