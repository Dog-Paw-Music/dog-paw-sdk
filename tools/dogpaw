    )
    return run_external([str(DEPLOY_HEADLESS_APPS_TOOL), *delegated_args])


def dispatch_app_install_flutter(args: Sequence[str]) -> int:
    """Dispatch `tools/dogpaw app install flutter`.

    Purpose:
        Implements a host-side remote Flutter install flow by syncing the
        selected app plus shared Flutter workspace packages/tools to the target
        Pi, then invoking the existing remote build-and-install script there.
    Parameters:
        args: Remaining arguments after `app install flutter`.
    Return value:
        Exit code from the dry-run print path or the first failing sync/build
        command.
    Requirements:
        Manifest path must exist and live under `FLUTTER_WORKSPACE_ROOT`.
    Guarantees:
        The sync set includes only shared `packages/`, the specific app tree,
        and the install scripts needed for the remote build.
    Invariants:
        Dry-run mode does not create, modify, or delete local or remote files.
    """

    parser = build_flutter_install_parser()
    parsed = parser.parse_args(list(args))
    try:
        context = resolve_flutter_manifest_context(parsed.manifest)
    except ValueError as exc:
        parser.error(str(exc))
        raise AssertionError("unreachable") from exc

    target = resolve_target(parsed.target)
    remote_source_root = PurePosixPath(parsed.remote_source_root)
    remote_app_root = PurePosixPath(parsed.remote_app_root)
    remote_flutter_root = PurePosixPath(parsed.remote_flutter_root)
    commands = build_flutter_source_sync_commands(
        context,
        target,
        remote_source_root,
        remote_app_root,
    )
    commands.append(
        [
            *SSH_BASE_ARGS,
            target,
            build_remote_flutter_install_command(
                context,
                remote_source_root,
                remote_app_root,
                remote_flutter_root,
                parsed.bridge_lib,
                parsed.build_mode,
            ),
        ]
    )
    return run_commands(commands, parsed.dry_run)


def dispatch_debug_flutter(args: Sequence[str]) -> int:
    """Dispatch `tools/dogpaw debug flutter`.

    Purpose:
        Implements the first host-driven remote Flutter debug flow by syncing a
        source checkout to the Pi, refreshing installed assets in the canonical
        app registry, then keeping a forwarded Dart VM service alive for local
        IDE attach.
    Parameters:
        args: Remaining arguments after `debug flutter`.
    Return value:
        Exit code from the dry-run print path or the first failing remote
        command.
    Requirements:
        Caller must provide `--manifest` plus either a fixed `--port`, an
        explicit `--local-port`, or an IDE-facing `--service-info-file` that
        allows the tool to choose a fresh local port automatically.
    Guarantees:
        The debugged app still reads installed assets from `DOGPAW_APP_DIR`
        rather than the temporary source tree.
    Invariants:
        Dry-run mode does not create, modify, or delete local or remote files.
    """

    parser = build_debug_flutter_parser()
    parsed = parser.parse_args(
        rewrite_local_path_option_values(
            args,
            {"--manifest", "--service-info-file"},
        )
    )
    try:
        context = resolve_flutter_manifest_context(parsed.manifest)
    except ValueError as exc:
        parser.error(str(exc))
        raise AssertionError("unreachable") from exc

    target = resolve_target(parsed.target)
    remote_source_root = PurePosixPath(parsed.remote_source_root)
    remote_app_root = PurePosixPath(parsed.remote_app_root)
    remote_flutter_root = PurePosixPath(parsed.remote_flutter_root)
    service_info_file = (
        resolve_local_cli_path(parsed.service_info_file)
        if parsed.service_info_file is not None
        else None
    )
    if parsed.port is not None and parsed.local_port is not None:
        parser.error("--port cannot be combined with --local-port")
        raise AssertionError("unreachable")
    if parsed.port is not None and parsed.remote_port is not None:
        parser.error("--port cannot be combined with --remote-port")
        raise AssertionError("unreachable")
    if parsed.port is not None:
        local_port = parsed.port
        remote_port = parsed.port
    else:
        remote_port = (
            parsed.remote_port
            if parsed.remote_port is not None
            else DEFAULT_REMOTE_FLUTTER_DEBUG_PORT
        )
        if parsed.stop:
            local_port = None
        elif parsed.local_port is not None:
            local_port = parsed.local_port
        elif parsed.dry_run:
            parser.error("--dry-run without --port requires --local-port")
            raise AssertionError("unreachable")
        else:
            local_port = choose_available_local_tcp_port()
    try:
        validate_tcp_port_text(remote_port, "--remote-port")
    except ValueError as exc:
        parser.error(str(exc))
        raise AssertionError("unreachable") from exc
    if parsed.stop:
        stop_command = [
            *SSH_BASE_ARGS,
            target,
            build_remote_flutter_stop_command(
                context=context,
                remote_source_root=remote_source_root,
                remote_port=remote_port,
            ),
        ]
        if parsed.dry_run:
            print(shell_join(stop_command))
            return 0
        return int(subprocess.run(stop_command, cwd=INVOCATION_CWD, check=False).returncode)
    if not parsed.dry_run and local_port is not None:
        try:
            ensure_local_tcp_port_available(local_port)
        except ValueError as exc:
            parser.error(str(exc))
            raise AssertionError("unreachable") from exc

    commands = build_flutter_source_sync_commands(
        context,
        target,
        remote_source_root,
        remote_app_root,
    )
    commands.append(
        [
            *SSH_BASE_ARGS,
            target,
            build_remote_flutter_install_command(
                context,
                remote_source_root,
                remote_app_root,
                remote_flutter_root,
                parsed.build_mode,
            ),
        ]
    )

    launch_command = [
        *SSH_BASE_ARGS,
        "-o",
        "ExitOnForwardFailure=yes",
        "-L",
        f"{local_port}:127.0.0.1:{remote_port}",
        target,
        build_remote_flutter_debug_command(
            context=context,
            remote_source_root=remote_source_root,
            remote_app_root=remote_app_root,
            remote_flutter_root=remote_flutter_root,
            bridge_lib=parsed.bridge_lib,
            instance_name=parsed.instance,
            remote_port=remote_port,
            device_id=parsed.device_id,
            start_paused=parsed.start_paused,
        ),
    ]

    if parsed.dry_run:
        for command in [*commands, launch_command]:
            print(shell_join(command))
        if service_info_file is not None:
            print(
                f"# vmServiceInfoFile {service_info_file} -> ws://127.0.0.1:{local_port}/ws"
            )
        return 0

    for command in commands:
        result = subprocess.run(command, cwd=INVOCATION_CWD, check=False)
        if result.returncode != 0:
            return result.returncode
    return stream_flutter_debug_launch(
        launch_command=launch_command,
        local_port=local_port,
        service_info_file=service_info_file,
    )


def dispatch_app(args: Sequence[str]) -> int:
    """Dispatch the `app` workflow area.

    Purpose:
        Provides the shared command family for idempotent app installation while
        allowing headless and Flutter flows to diverge internally.
    Parameters:
        args: Remaining command-line arguments after `app`.
    Return value:
        Exit code from the selected app workflow, or `2` for invalid usage.
    Requirements:
        None.
    Guarantees:
        `app install headless ...` and `app install flutter ...` are routed to
        the appropriate implementations.
    Invariants:
        Unsupported app subcommands do not silently fall through.
    """

    if is_help_request(args):
        print_app_help()
        return 0
    if EXPORTED_SDK:
        print(exported_sdk_v1_message("app", args), file=sys.stderr)
        return 2
    if args[0] != "install":
        print(f"Unsupported app command: {args[0]}", file=sys.stderr)
        print_app_help()
        return 2
    if len(args) == 1:
        print("Usage: dogpaw app install <headless|flutter> [options]", file=sys.stderr)
        return 2
    if args[1] == "headless":
        return dispatch_app_install_headless(args[2:])
    if args[1] == "flutter":
        return dispatch_app_install_flutter(args[2:])
    print(f"Unsupported app install target: {args[1]}", file=sys.stderr)
    print("Usage: dogpaw app install <headless|flutter> [options]", file=sys.stderr)
    return 2


def dispatch_debug_cxx(args: Sequence[str]) -> int:
    """Dispatch `tools/dogpaw debug cxx`.

    Purpose:
        Bridges install-aware headless app preparation with the existing
        `deploy_and_run.sh` gdbserver launcher while still supporting direct
        binary debug flows for non-app targets such as Epiphany and tests.
    Parameters:
        args: Remaining arguments after `debug cxx`.
    Return value:
        Exit code from the dry-run print path or the first failing install/launch
        command.
    Requirements:
        Caller must provide `--port` and either `--manifest` or `--binary`.
    Guarantees:
        Manifest-backed launches install the app first and then debug the
        installed bundle path. Direct-binary launches keep the existing
        deploy-and-run behavior behind the new front door.
    Invariants:
        Dry-run mode does not create, modify, or delete local or remote files.
    """

    parser = build_debug_cxx_parser()
    wrapper_args, binary_args = split_passthrough_args(args)
    wrapper_args = rewrite_local_path_option_values(
        wrapper_args,
        {"--manifest", "--binary", "--build-dir", "--sync", "-s", "--sync-asset"},
    )
    parsed = parser.parse_args(wrapper_args)

    if parsed.manifest is None and parsed.binary is None:
        parser.error("either --manifest or --binary is required")
    if parsed.manifest is not None and (len(parsed.sync) > 0 or len(parsed.sync_asset) > 0 or parsed.asset_dest is not None):
        parser.error("--manifest mode does not support --sync, --sync-asset, or --asset-dest; use direct --binary mode for that workflow")

    target = resolve_target(parsed.target)
    commands: list[list[str]] = []

    if parsed.manifest is not None:
        manifest_path = resolve_local_cli_path(parsed.manifest)
        if not manifest_path.is_file():
            parser.error(f"manifest not found: {manifest_path}")
        manifest_payload = load_manifest_payload(manifest_path)
        app_name = require_manifest_string_field(manifest_path, manifest_payload, "name")
        executable_name = require_manifest_string_field(manifest_path, manifest_payload, "executable")
        build_dir = resolve_local_cli_path(parsed.build_dir)
        binary_path = (
            resolve_local_cli_path(parsed.binary)
            if parsed.binary is not None
            else (build_dir / "bin" / executable_name)
        )
        if not binary_path.is_file():
            parser.error(f"binary not found: {binary_path}")

        install_command = [
            str(DEPLOY_HEADLESS_APPS_TOOL),
            "--target",
            target,
            "--build-dir",
            str(build_dir),
            "--hardware-profile",
            parsed.hardware_profile,
            "--manifest",
            str(manifest_path),
        ]
        if parsed.dry_run:
            install_command.append("--dry-run")
        commands.append(install_command)

        remote_bundle_dir = PurePosixPath(parsed.remote_app_root) / app_name / "bundle"
        remote_env = append_env_if_missing(parsed.env, f"DOGPAW_APP_DIR={parsed.remote_app_root}")
        debug_command = [
            str(DEPLOY_AND_RUN_TOOL),
            "-t",
            target,
            "-p",
            parsed.port,
            "--no-deploy",
            "-d",
            str(remote_bundle_dir),
        ]
        if parsed.workdir is not None:
            debug_command.extend(["-w", parsed.workdir])
        if parsed.interactive_stdin:
            debug_command.append("--interactive-stdin")
        elif parsed.non_interactive_stdin:
            debug_command.append("--non-interactive-stdin")
        for assignment in remote_env:
            debug_command.extend(["--env", assignment])
        debug_command.append(str(binary_path))
        if len(binary_args) > 0:
            debug_command.append("--")
            debug_command.extend(binary_args)
        commands.append(debug_command)
        return run_commands(commands, parsed.dry_run)

    binary_path = resolve_local_cli_path(parsed.binary)
    if not binary_path.is_file():
        parser.error(f"binary not found: {binary_path}")

    debug_command = [
        str(DEPLOY_AND_RUN_TOOL),
        "-t",
        target,
        "-p",
        parsed.port,
    ]
    if parsed.workdir is not None:
        debug_command.extend(["-w", parsed.workdir])
    if parsed.interactive_stdin:
        debug_command.append("--interactive-stdin")
    elif parsed.non_interactive_stdin:
        debug_command.append("--non-interactive-stdin")
    for sync_path in parsed.sync:
        debug_command.extend(["-s", sync_path])
    for assignment in parsed.env:
        debug_command.extend(["--env", assignment])
    for asset_path in parsed.sync_asset:
        debug_command.extend(["--sync-asset", asset_path])
    if parsed.asset_dest is not None:
        debug_command.extend(["--asset-dest", parsed.asset_dest])
    debug_command.append(str(binary_path))
    if len(binary_args) > 0:
        debug_command.append("--")
        debug_command.extend(binary_args)
    return run_commands([debug_command], parsed.dry_run)


