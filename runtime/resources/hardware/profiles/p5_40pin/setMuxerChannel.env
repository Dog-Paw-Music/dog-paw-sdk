# Pin definitions for setMuxerChannel.sh - p5_40pin profile
#
# The p5_40pin hardware drives four GPIO pins directly with the 4-bit binary
# channel number. MUXER_GPIO_PINS lists BCM GPIO numbers from LSB (bit 0) to
# MSB (bit 3). Channels 0-7 address the blades; channel 8 addresses the shadow blade.
#
MUXER_MODE=gpio_direct

# MUX_SHIFT_BIT_ORDER applies only when MUXER_MODE=shift_register (not used here).
MUX_SHIFT_BIT_ORDER=cm5
MUXER_GPIO_PINS=(13 26 5 6)    # bit0=GPIO13, bit1=GPIO26, bit2=GPIO5, bit3=GPIO6

# Blade channel layout
# Channels 0-7 = regular blades 0-7; channel 8 = shadow blade
SHADOW_BLADE_CHANNEL=8
BLADE_CHANNEL_OFFSET=0
