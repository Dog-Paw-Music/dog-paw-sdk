# Pin definitions for setMuxerChannel.sh - P8.2 carrier (CM5-class Pi host)
#
# 74HC164 + dual CD74HC4067. SEL_CODE_* map logical channel to each mux's S-code.
# MUX_SHIFT_BIT_ORDER selects how AS/BS lines map to serial bits (see setMuxerChannel.sh).
MUXER_MODE=shift_register
BSC_PIN=26
BSD_PIN=27

# 74HC164 serial bit order (b1 first): p8_2 = BS1,BS0,BS3,BS2,AS2,AS3,AS0,AS1
MUX_SHIFT_BIT_ORDER=p8_2

# Lookup tables (must match Mux74HC164.hpp selCodeForA/B when ioboard is used)
SEL_CODE_A=(13 15 2 7 6 5 9 11 3 4)    # A0-A8
SEL_CODE_B=(15 3 2 7 6 9 5 13 4 11)  # B0-B8

# Blade channel layout
# Channel 0 = shadow blade; channels 1-8 = regular blades 0-7
SHADOW_BLADE_CHANNEL=0
BLADE_CHANNEL_OFFSET=1
