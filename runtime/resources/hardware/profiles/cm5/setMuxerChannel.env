# Pin definitions for setMuxerChannel.sh - CM5 profile
#
# The CM5 hardware drives a 74HC164 shift register via BSC_PIN (clock) and
# BSD_PIN (data). SEL_CODE_A and SEL_CODE_B are lookup tables that map a
# channel number (0-8) to the 8-bit shift-register patterns for each muxer.
MUXER_MODE=shift_register
BSC_PIN=26
BSD_PIN=27

# 74HC164 serial bit order (b1 first): cm5 = BS1,BS0,BS2,BS3,AS1,AS0,AS2,AS3
MUX_SHIFT_BIT_ORDER=cm5

# Lookup tables matching C++ selCodeForA and selCodeForB
SEL_CODE_A=(7 6 5 4 3 11 10 9 8)    # A0-A8
SEL_CODE_B=(7 5 6 3 4 14 15 13 12)  # B0-B8

# Blade channel layout
# Channel 0 = shadow blade; channels 1-8 = regular blades 0-7
SHADOW_BLADE_CHANNEL=0
BLADE_CHANNEL_OFFSET=1
